  marketplaces ResearchMarketplace[]
  productLimit Int                      @default(50)
  status       ProductDiscoveryStatus   @default(PENDING)
  productCount Int                      @default(0)
  errorMessage String?
  /** Progress scrape multi-marketplace + peringatan per platform. */
  scrapeState  Json?
  /** Rencana aksi preskriptif hasil analisis (ActionPlan). */
  aiActionPlan Json?
  /** Ringkasan & metrik analisis pasar (price band, velocity, whitespace). */
  aiInsights   Json?
  /** Metadata model AI yang dipakai saat analisis terakhir. */
  aiMeta       Json?
  createdById  String
  createdBy    User                     @relation("ProductDiscoveryCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
