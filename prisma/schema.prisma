  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([artifactType, artifactId, createdById])
  @@index([module, createdAt])
}

enum RecOwner {
  MARKETING
  RND
  PRICING
  FINANCE
  SUPPLY
  BRAND
}

/// Rekomendasi preskriptif lintas-modul yang menyalakan Action Center di dashboard.
model ResearchRecommendation {
  id                String    @id @default(cuid())
  /**
   * Modul asal: "review-intelligence", "competitor-tracker", dst.
   */
  module            String
  /**
   * Id record sumber (sourceId/digestId/queryId/analysisId/conceptId).
   */
  sourceId          String?
  /**
   * Label sumber agar bisa di-deep-link dari UI.
   */
  sourceLabel       String?
  /**
   * Path deep-link ke detail sumber.
   */
  href              String?
  owner             RecOwner
  priority          String    @default("P1")
  action            String    @db.Text
  rationale         String    @db.Text
  expectedImpact    String?   @db.Text
  metricToWatch     String?
  evidence          Json      @default("[]")
  confidence        Float     @default(0.6)
  effort            String    @default("MED")
  horizon           String    @default("30D")
  status            RecStatus @default(OPEN)
  /**
   * Task hasil konversi (lineage rekomendasi → aksi nyata).
   */
  convertedToTaskId String?
  dismissedAt       DateTime?
  convertedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([module, sourceId])
  @@index([owner])
}

