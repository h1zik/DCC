  text           String                 @db.Text
  author         String?
  url            String?
  likes          Int                    @default(0)
  comments       Int                    @default(0)
  views          Int                    @default(0)
  classification SocialMentionClass     @default(NEUTRAL)
  painPoint      String?
  isViral        Boolean                @default(false)
  postedAt       DateTime?
  thumbnailUrl   String?
  mediaType      String?
  createdAt      DateTime               @default(now())

  @@unique([batchId, platform, externalId])
  @@index([batchId])
  @@index([classification])
}

model BrandSocialSummary {
  id                String             @id @default(cuid())
  batchId           String             @unique
  batch             BrandSocialBatch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  topPainPoints     Json               @default("[]")
  topWishlist       Json               @default("[]")
  influencers       Json               @default("[]")
  viralContent      Json               @default("[]")
  categoryBreakdown Json               @default("[]")
  aiSummary         String?            @db.Text
  aiActionPlan      Json?
  aiMeta            Json?
  sentimentTimeline Json               @default("[]")
  updatedAt         DateTime           @updatedAt
}

model BrandUspAnalysis {
  id             String        @id @default(cuid())
  category       String
  ownerBrandId   String?
  ownerBrand     Brand?        @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  contextModules Json          @default("{}")
  status         UspGapStatus  @default(PENDING)
  errorMessage   String?
  createdById    String
  createdBy      User          @relation("BrandUspAnalysisCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  result         BrandUspResult?

  @@index([createdById])
  @@index([status])
  @@index([ownerBrandId])
}

model BrandUspResult {
  id                   String             @id @default(cuid())
  analysisId           String             @unique
  analysis             BrandUspAnalysis   @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  gapMatrix            Json               @default("[]")
  claimAnalysis        Json               @default("{}")
  positioningMap       Json               @default("{}")
  uspCandidates        Json               @default("[]")
  differentiationScore Float?
  aiSummary            String?            @db.Text
  aiActionPlan         Json?
  categoryDecision     Json?
  aiMeta               Json?
  updatedAt            DateTime           @updatedAt
}

model BrandResearchScrapeJob {
  id          String                  @id @default(cuid())
  type        ResearchScrapeJobType
  entityId    String
  apifyRunId  String?
  status      ResearchScrapeJobStatus @default(PENDING)
  error       String?                 @db.Text
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime                @default(now())
  stepLabel   String?
  percent     Int                     @default(0)
  currentStep Int?
  totalSteps  Int?

  @@index([status])
  @@index([entityId, type])
  @@index([apifyRunId])
}

enum BrandVisualAssetSource {
  PINTEREST
  COMPETITOR_LISTING
  SOCIAL
  MANUAL
}

enum BrandVisualCollectionStatus {
  PENDING
  COLLECTING
  READY
  FAILED
}

enum BrandStrategyStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

enum BrandCreativeGuidelineStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

model BrandVisualCollection {
  id                 String                      @id @default(cuid())
  name               String
  keywords           String[]                    @default([])
  maxPinsPerKeyword  Int?
  status             BrandVisualCollectionStatus @default(PENDING)
  sourceConfig Json?
  errorMessage String?
  ownerBrandId String?
  ownerBrand   Brand?                      @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  createdById  String
  createdBy    User                        @relation("BrandVisualCollectionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt
  assets       BrandVisualAsset[]

  @@index([createdById])
  @@index([ownerBrandId])
  @@index([status])
}

model BrandVisualAsset {
  id             String                 @id @default(cuid())
  collectionId   String?
  collection     BrandVisualCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  ownerBrandId   String?
  ownerBrand     Brand?                 @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  source         BrandVisualAssetSource
  imageUrl       String
  thumbnailUrl   String?
  title          String?
  description    String?                @db.Text
  sourceUrl      String?
  externalId     String?
  tags           String[]               @default([])
  aestheticTags  String[]               @default([])
  dominantColors Json?
  metadata       Json?
  createdAt      DateTime               @default(now())

  @@unique([collectionId, source, externalId])
  @@index([collectionId])
  @@index([ownerBrandId])
  @@index([source])
}

model BrandStrategyDocument {
  id               String              @id @default(cuid())
  ownerBrandId     String?
  ownerBrand       Brand?              @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  version          Int                 @default(1)
  status           BrandStrategyStatus @default(DRAFT)
  brandPurpose     String?             @db.Text
  brandEssence     String?             @db.Text
  coreMessage      String?             @db.Text
  brandUsp         String?             @db.Text
  stp              Json?
  brandPersonality Json?
  toneOfVoice      Json?
  evidenceRefs     Json                @default("[]")
  /** User-selected modules/entities fed to AI at generation time. */
  generationConfig Json                @default("{}")
  /** Per-field detailed reasoning from AI generation. */
  strategyRationales Json              @default("[]")
  /** Deterministic input fed to AI at generation time (audit trail). */
  evidenceSnapshot Json                @default("{}")
  aiMeta           Json?
  errorMessage     String?
  createdById      String
  createdBy        User                @relation("BrandStrategyDocumentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  creativeGuidelines BrandCreativeGuideline[]

  @@index([createdById])
  @@index([ownerBrandId])
  @@index([status])
}

model BrandCreativeGuideline {
  id                 String                       @id @default(cuid())
  strategyDocumentId String?
  strategyDocument   BrandStrategyDocument?       @relation(fields: [strategyDocumentId], references: [id], onDelete: SetNull)
  ownerBrandId       String?
  ownerBrand         Brand?                       @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  status             BrandCreativeGuidelineStatus @default(PENDING)
  moodboardAssetIds  Json                         @default("[]")
  colorPalette       Json?
  typography         Json?
  designReferences   Json                         @default("[]")
  aiSummary          String?                      @db.Text
  aiMeta             Json?
  errorMessage       String?
  createdById        String
  createdBy          User                         @relation("BrandCreativeGuidelineCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([createdById])
  @@index([ownerBrandId])
  @@index([strategyDocumentId])
  @@index([status])
}
