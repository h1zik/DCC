enum ProductConceptMode {
  MANUAL
  AI_GENERATED
}

enum ProductConceptStatus {
  DRAFT
  VALIDATING
  READY
  /// Sudah dikirim ke R&D — cegah duplikasi project diam-diam.
  SENT_TO_RND
  ARCHIVED
}

model ProductConcept {
  id                String               @id @default(cuid())
  title             String
  category          String
  targetMarket      String?
  priceTargetMin    Float?
  priceTargetMax    Float?
  mode              ProductConceptMode   @default(MANUAL)
  status            ProductConceptStatus @default(DRAFT)
  brandId           String?
  brand             Brand?               @relation(fields: [brandId], references: [id], onDelete: SetNull)
  uspGapAnalysisId  String?
  uspGapAnalysis    UspGapAnalysis?      @relation(fields: [uspGapAnalysisId], references: [id], onDelete: SetNull)
  uspIndex          Int?
  sourceModules     Json                 @default("{}")
  conceptData       Json                 @default("{}")
  validationScores  Json                 @default("{}")
  /**
   * Faktor risiko deterministik (mis. keluhan review) dengan evidence ref.
   */
  riskFactors       Json                 @default("[]")
  /**
   * Metadata model AI per langkah (generate, validate, compare).
   */
  aiMeta            Json?
  createdById       String
  createdBy         User                 @relation("ProductConceptCreator", fields: [createdById], references: [id], onDelete: Cascade)
  /**
   * Waktu terakhir dikirim ke R&D (sendConceptToRdTask).
   */
  sentToRdAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  innovationsSeeded ProductInnovation[]  @relation("InnovationBaseConcept")
  projects          Project[]            @relation("ProjectSourceConcept")

  @@index([createdById])
  @@index([status])
  @@index([brandId])
  @@index([uspGapAnalysisId])
}

/**
 * Product Innovation (SCAMPER) — sesi ideasi yang menerapkan 6 lensa SCAMPER
 * (Substitute, Combine, Adapt, Put to other use, Eliminate, Reverse/Rearrange)
 * pada produk basis, di-grounding evidence riset. Tiap ide bisa dipromosikan
 * menjadi ProductConcept di Concept Lab.
 */
model ProductInnovation {
  id               String                  @id @default(cuid())
  title            String
  category         String
  /**
   * Produk basis yang ditransformasi (teks bebas).
   */
  baseProduct      String
  targetMarket     String?
  priceTargetMin   Float?
  priceTargetMax   Float?
  /**
   * Opsional: konsep Concept Lab sumber prefill.
   */
  baseConceptId    String?
  baseConcept      ProductConcept?         @relation("InnovationBaseConcept", fields: [baseConceptId], references: [id], onDelete: SetNull)
  brandId          String?
  brand            Brand?                  @relation(fields: [brandId], references: [id], onDelete: SetNull)
  status           ProductInnovationStatus @default(DRAFT)
  /**
   * Toggle modul evidence (reuse bentuk sourceModules Concept Lab).
   */
  sourceModules    Json                    @default("{}")
  /**
   * Array ide SCAMPER: tiap item { id, technique, title, description,
   * rationale, change, benefit, feasibilityNote, promotedConceptId? }.
   */
  ideas            Json                    @default("[]")
  /**
   * Faktor risiko deterministik dari evidence (deriveRiskFactors).
   */
  riskFactors      Json                    @default("[]")
  evidenceSnapshot Json                    @default("{}")
  aiMeta           Json?
  errorMessage     String?
  createdById      String
  createdBy        User                    @relation("ProductInnovationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([createdById])
  @@index([status])
  @@index([brandId])
}

enum ProductInnovationStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

enum ResearchReportType {
  WEEKLY
  CUSTOM
  CATEGORY_DEEP_DIVE
  COMPETITOR_BATTLE
  TREND_BRIEF
}

enum ResearchReportStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

model ResearchReport {
  id           String                   @id @default(cuid())
  title        String
  type         ResearchReportType
  status       ResearchReportStatus     @default(PENDING)
  config       Json                     @default("{}")
  sections     Json                     @default("[]")
  aiSummary    String?                  @db.Text
  /**
   * Cross-module action items (deterministic, dari ResearchRecommendation).
   */
  actionItems  Json                     @default("[]")
  /**
   * Feedback-loop Sankey data: signal -> insight -> concept.
   */
  feedbackLoop Json?
  /**
   * Aktivitas modul untuk chart ringkasan.
   */
  metrics      Json?
  /**
   * Metadata model AI yang dipakai saat generate laporan.
   */
  aiMeta       Json?
  periodStart  DateTime?
  periodEnd    DateTime?
  errorMessage String?
  /**
   * Nomor versi konten aktif; naik setiap regenerate. Versi lama diarsip di revisions.
   */
  version      Int                      @default(1)
  createdById  String
  createdBy    User                     @relation("ResearchReportCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  revisions    ResearchReportRevision[]

  @@index([createdById])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

/// Snapshot versi lama laporan — regenerate tidak lagi menimpa riwayat.
model ResearchReportRevision {
  id          String         @id @default(cuid())
  reportId    String
  report      ResearchReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  version     Int
  sections    Json           @default("[]")
  aiSummary   String?        @db.Text
  actionItems Json           @default("[]")
  metrics     Json?
  aiMeta      Json?
  /**
   * Kapan versi ini di-generate (sebelum digantikan).
   */
  generatedAt DateTime
  createdAt   DateTime       @default(now())

  @@unique([reportId, version])
  @@index([reportId])
}

enum RecStatus {
  OPEN
  DISMISSED
  CONVERTED
  /// Digantikan hasil analisis yang lebih baru — dipertahankan sebagai riwayat, bukan dihapus.
  SUPERSEDED
}

/// Riwayat eksekusi cron research-sync — untuk panel kesehatan data & deteksi data basi.
model ResearchCronRun {
  id         String    @id @default(cuid())
  /**
   * Mode cron: poll | competitors | trends | social | reports.
   */
  mode       String
  status     String    @default("RUNNING")
  detail     String?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  @@index([mode, startedAt])
}

enum AiFeedbackVerdict {
  UP
  DOWN
}

/// Feedback user pada output AI (thumbs + flag salah) — bahan kalibrasi kualitas.
model AiOutputFeedback {
  id           String            @id @default(cuid())
  /**
   * Modul asal: usp-analyzer, concept-lab, recommendations, dst.
   */
  module       String
  /**
   * Jenis artefak: recommendation | usp-candidate | concept-validation | report-summary | ...
   */
  artifactType String
  artifactId   String
  verdict      AiFeedbackVerdict
  note         String?           @db.Text
  /**
   * Snapshot aiMeta artefak saat feedback diberikan (model, prompt version).
   */
  aiMeta       Json?
  createdById  String
