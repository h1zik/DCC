generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockLogType {
  IN
  OUT
}

/**
 * Tahap pipeline produk (urutan alur bisnis).
 */
enum PipelineStage {
  MARKET_RESEARCH
  PRODUCT_DEVELOPMENT
  BRAND_AND_DESIGN
  PANEL_TESTING
  PRODUCTION
  PRELAUNCH
  LAUNCH
}

/**
 * Peran vendor dalam rantai pasok satu SKU (contoh parfum: botol, packaging, maklon).
 */
enum ProductVendorRole {
  MAKLON
  BOTTLE
  PACKAGING
  RAW_MATERIAL
  OTHER
}

enum UserRole {
  CEO
  /**
   * Mengelola master brand & ruang kerja; ditetapkan oleh CEO.
   */
  ADMINISTRATOR
  LOGISTICS
  /**
   * Member umum — akses tugas, ruangan, dan pipeline (level studio).
   */
  NORMAL_USER
  PROJECT_MANAGER
  /**
   * Akuntansi & treasury; akses modul keuangan.
   */
  FINANCE
  /**
   * @deprecated dipindah ke NORMAL_USER. Disisakan agar data lama tidak rusak.
   */
  MARKETING
  /**
   * @deprecated dipindah ke NORMAL_USER.
   */
  CREATIVE_DIRECTOR
  /**
   * @deprecated dipindah ke NORMAL_USER.
   */
  BUSINESS_ANALYST
  /**
   * @deprecated dipindah ke NORMAL_USER.
   */
  COPYWRITER
  /**
   * Market Analyst — akses Research Hub + studio workspace.
   */
  MARKET_ANALYST
}

enum KanbanColumnKind {
  CORE
  CUSTOM
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  OVERDUE
  DONE
  /**
   * Tertunda / menunggu pihak lain — kolom Kanban opsional per ruangan.
   */
  BLOCKED
  /**
   * Siap ditinjau — kolom Kanban opsional per ruangan.
   */
  IN_REVIEW
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum NotificationType {
  TASK_COMPLETED
  TASK_OVERDUE
  /**
   * Komentar pada lampiran tugas ditugaskan ke anggota tim.
   */
  TASK_FILE_COMMENT_ASSIGNED
  /**
   * Komentar pada dokumen ruangan ditugaskan ke anggota tim.
   */
  ROOM_DOCUMENT_COMMENT_ASSIGNED
  CEO_APPROVAL_REQUESTED
  /**
   * Pengajuan pindah tahap pipeline proyek menunggu CEO.
   */
  PROJECT_PIPELINE_APPROVAL_REQUESTED
  /**
   * Pengingat jadwal acara / meeting (H-1 & ~1 jam sebelum mulai).
   */
  SCHEDULE_REMINDER
  /**
   * Alert dari modul Research Hub (Competitor Tracker, dll).
   */
  RESEARCH_ALERT
}

/**
 * Jenis pengingat jadwal yang sudah dikirim (anti duplikat).
 */
enum ScheduleReminderKind {
  DAY_BEFORE
  HOUR_BEFORE
}

/**
 * Pengelompokan ruangan di menu Tugas & Kanban (ditetapkan CEO).
 */
enum RoomWorkspaceSection {
  HQ
  TEAM
  ROOMS
}

/**
 * Peran anggota di dalam satu ruangan (ditetapkan CEO).
 */
enum RoomMemberRole {
  /**
   * Mengelola tugas di fase yang ditetapkan (`allowedRoomProcesses`).
   */
  ROOM_MANAGER
  /**
   * Bekerja pada tugas di fase yang ditetapkan.
   */
  ROOM_CONTRIBUTOR
  /**
   * Akses semua fase proses tugas di ruangan ini (setara kuasa kelola tugas).
   */
  ROOM_PROJECT_MANAGER
}

/**
 * Tahap alur kerja per ruangan — memisahkan tugas di hub ruangan.
 */
enum RoomTaskProcess {
  MARKET_RESEARCH
  PRODUCT_DEVELOPMENT
  BRAND_AND_DESIGN
  PANEL_TESTING
  PRE_LAUNCH
  PRODUCTION
}

enum ContentPlanJenis {
  REELS
  CAROUSEL
  SINGLE_FEED
}

/**
 * Funnel usage / objective konten di content planning.
 */
enum ContentPlanUsage {
  AWARENESS
  CONSIDERATION
  CONVERSION
}

/**
 * Status alur copywriting & design di content planning.
 */
enum ContentPlanStatusKerja {
  BARU
  DALAM_PROSES
  DALAM_PENINJAUAN
  DIPUBLIKASIKAN
  DITANGGUHKAN
  DIJEDA
}

enum ScheduleRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum TaskWorkspaceView {
  KANBAN
  LIST
  GANTT
  CALENDAR
}

/**
 * Jenis view tambahan yang dapat ditambahkan room manager ke ruangan
 * (di luar menu wajib: Tasks, Grup, Anggota, Content Planning, Documents).
 */
enum RoomViewType {
  CALENDAR
  TIMELINE
  WIKI
  LINKS
  LIST
  GLOSSARY
}

enum RoomTimelineStatus {
  UPCOMING
  IN_PROGRESS
  DONE
  BLOCKED
}

/**
 * Tipe kolom untuk view LIST generik (kolom kustom).
 */
enum RoomListColumnType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  SELECT
  URL
}

model User {
  id                        String                         @id @default(cuid())
  name                      String?
  email                     String                         @unique
  emailVerified             DateTime?
  image                     String?
  /**
   * Aktivitas terakhir user di aplikasi (untuk indikator online).
   */
  lastSeenAt                DateTime?
  /**
   * Deskripsi singkat / bio (opsional, untuk profil).
   */
  bio                       String?
  /**
   * Nomor WhatsApp format E.164 (mis. +6281234567890) untuk notifikasi Twilio.
   */
  whatsappPhone             String?
  /**
   * Tema banner profil publik (slug preset gradien).
   * @see `PROFILE_BANNER_PRESETS` di kode.
   */
  profileBannerPreset       String                         @default("twilight")
  /**
   * Slogan singkat di bawah nama (dipublikasikan ke profil publik).
   */
  profileTagline            String?                        @db.VarChar(160)
  /**
   * Warna aksen hex `#RRGGBB` untuk ring avatar & aksen; null = pakai default tema.
   */
  profileAccentHex          String?                        @db.VarChar(7)
  /**
   * Pola dekoratif di banner (slug). Lihat `PROFILE_BANNER_PATTERNS`.
   */
  profileBannerPattern      String                         @default("noise")
  /**
   * Slug stiker / lambang kecil di samping nama (mahkota, bintang, dll). Null = tanpa stiker.
   * Lihat `PROFILE_STICKERS`.
   */
  profileSticker            String?                        @db.VarChar(24)
  /**
   * Bentuk frame avatar (slug). Lihat `PROFILE_AVATAR_FRAMES`.
   */
  profileAvatarFrame        String                         @default("ring")
  /**
   * Preset tema UI aplikasi (slug). Lihat `APP_THEME_PRESETS` di kode.
   */
  appThemePreset            String                         @default("original")
  /**
   * Tampilan default modul Tasks saat membuka ruangan.
   */
  taskDefaultWorkspaceView  TaskWorkspaceView              @default(KANBAN)
  passwordHash              String
  /**
   * Tier permission sistem (CEO/Administrator/Finance/Logistik/...) — tetap menjadi
   * sumber kebenaran untuk middleware, sidebar, dan akses modul. Custom role
   * (label peran) disimpan terpisah di `customRoleId` dan hanya untuk display.
   */
  role                      UserRole                       @default(LOGISTICS)
  /**
   * Label peran kustom yang dipilih CEO/Admin (mis. "Creative Director",
   * "DevOps Engineer"). Bila null, label peran berasal dari enum `role`.
   * Permission tier sebenarnya tetap mengikuti `role`.
   */
  customRoleId              String?
  customRole                CustomRole?                    @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  createdAt                 DateTime                       @default(now())
  updatedAt                 DateTime                       @updatedAt
  taskAssignments           TaskAssignee[]
  notifications             Notification[]
  pushSubscriptions         PushSubscription[]
  taskComments              TaskComment[]
  taskAttachments           TaskAttachment[]
  taskAttachmentCommentsAuthored TaskAttachmentComment[] @relation("TaskAttachmentCommentAuthor")
  taskAttachmentCommentsAssigned TaskAttachmentComment[] @relation("TaskAttachmentCommentAssignee")
  roomDocumentCommentsAuthored   RoomDocumentComment[]   @relation("RoomDocumentCommentAuthor")
  roomDocumentCommentsAssigned   RoomDocumentComment[]   @relation("RoomDocumentCommentAssignee")
  roomMessages              RoomMessage[]
  roomChannelReads          RoomChannelRead[]
  directConversationMembers DirectConversationMember[]
  directMessages            DirectMessage[]
  roomDocuments             RoomDocument[]
  roomMembers               RoomMember[]
  contentPlanItemsCreated   RoomContentPlanItem[]          @relation("ContentPlanItemCreator")
  contentPlanItemsAsPic     RoomContentPlanItem[]          @relation("ContentPlanItemPic")
  scheduleEventsCreated     ScheduleEvent[]                @relation("ScheduleEventCreator")
  scheduleParticipations    ScheduleEventParticipant[]
  scheduleReminderLogs      ScheduleReminderSent[]
  financeJournalEntries     FinanceJournalEntry[]
  financeApPaymentsRecorded FinanceApPayment[]             @relation("FinanceApPaymentRecorder")
  financeArPaymentsRecorded FinanceArPayment[]             @relation("FinanceArPaymentRecorder")
  financeSpendRequests      FinanceSpendRequest[]          @relation("FinanceSpendRequester")
  financeSpendApprovals     FinanceSpendRequest[]          @relation("FinanceSpendApprover")
  financePeriodLocks        FinancePeriodLock[]
  financeJournalAttachments FinanceJournalLineAttachment[] @relation("FinanceJournalLineAttachmentUploader")
  faceData                  FaceData[]
  attendances               Attendance[]
  reviewIntelSourcesCreated ReviewIntelSource[]  @relation("ReviewIntelSourceCreator")
  productDiscoveryQueriesCreated ProductDiscoveryQuery[] @relation("ProductDiscoveryCreator")
  researchCompetitorsCreated ResearchCompetitor[] @relation("ResearchCompetitorCreator")
  trendWatchlistsCreated    TrendWatchlist[]     @relation("TrendWatchlistCreator")
  trendRadarUserSettings    TrendRadarUserSettings?
  keywordIntelQueriesCreated KeywordIntelQuery[] @relation("KeywordIntelQueryCreator")
  socialListeningMonitorsCreated SocialListeningMonitor[] @relation("SocialListeningMonitorCreator")
  uspGapAnalysesCreated     UspGapAnalysis[]     @relation("UspGapAnalysisCreator")
  productConceptsCreated    ProductConcept[]     @relation("ProductConceptCreator")
  researchReportsCreated    ResearchReport[]     @relation("ResearchReportCreator")
  brandCompetitorsCreated   BrandCompetitor[]    @relation("BrandCompetitorCreator")
  brandReviewSourcesCreated BrandReviewSource[]  @relation("BrandReviewSourceCreator")
  brandKeywordQueriesCreated BrandKeywordQuery[] @relation("BrandKeywordQueryCreator")
  brandSocialMonitorsCreated BrandSocialMonitor[] @relation("BrandSocialMonitorCreator")
  brandUspAnalysesCreated   BrandUspAnalysis[]   @relation("BrandUspAnalysisCreator")
  brandVisualCollectionsCreated BrandVisualCollection[] @relation("BrandVisualCollectionCreator")
  brandStrategyDocumentsCreated BrandStrategyDocument[] @relation("BrandStrategyDocumentCreator")
  brandCreativeGuidelinesCreated BrandCreativeGuideline[] @relation("BrandCreativeGuidelineCreator")
  stockLogsCreated          StockLog[]           @relation("StockLogCreator")

  @@index([customRoleId])
}

/**
 * Label peran (job title) yang dapat dibuat dan diberi nama bebas oleh CEO/Admin.
 * Menyimpan nama tampilan + tier permission sistem yang mendasarinya.
 * - 4 role inti (CEO/Administrator/Finance/Logistik) dibuat sebagai `isProtected`
 * dan tidak dapat dihapus, hanya bisa diganti nama (opsional).
 * - Role lain bisa dibuat bebas. Permission yang dipakai sistem ditentukan oleh
 * `permissionTier` (mis. role kustom "DevOps Engineer" dengan tier `LOGISTICS`).
 */
model CustomRole {
  id             String   @id @default(cuid())
  /**
   * Nama tampilan (mis. "Creative Director"). Unik agar tidak ambigu.
   */
  name           String   @unique @db.VarChar(80)
  /**
   * Tier permission sistem yang dipakai user dengan role ini.
   * Saat user di-assign ke CustomRole, `User.role` di-set menyamai nilai ini.
   */
  permissionTier UserRole
  /**
   * Slug stabil (lowercase). Wajib unik agar bisa dipakai sebagai identifier
   * default untuk seed/lookup. Tidak ditampilkan ke user.
   */
  slug           String   @unique @db.VarChar(80)
  /**
   * Role inti yang dipastikan selalu ada — tidak boleh dihapus oleh user.
   */
  isProtected    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  users          User[]

  @@index([permissionTier])
}

model PushSubscription {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastUsedAt DateTime?

  @@index([userId])
}

model Brand {
  id                   String                @id @default(cuid())
  name                 String
  logo                 String?
  colorCode            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  products             Product[]
  projects             Project[]
  rooms                Room[]
  financeJournalLines  FinanceJournalLine[]
  financeApBills       FinanceApBill[]
  financeArInvoices    FinanceArInvoice[]
  financeBudgetLines   FinanceBudgetLine[]
  financeSpendRequests FinanceSpendRequest[]
  reviewIntelSources   ReviewIntelSource[]
  uspGapAnalyses       UspGapAnalysis[]
  productConcepts      ProductConcept[]
  brandCompetitors     BrandCompetitor[]
  brandReviewSources   BrandReviewSource[]
  brandTrendDigests    BrandTrendDigest[]
  brandKeywordQueries  BrandKeywordQuery[]
  brandSocialMonitors  BrandSocialMonitor[]
  brandUspAnalyses     BrandUspAnalysis[]
  brandVisualCollections BrandVisualCollection[]
  brandVisualAssets    BrandVisualAsset[]
  brandStrategyDocuments BrandStrategyDocument[]
  brandCreativeGuidelines BrandCreativeGuideline[]
}

/**
 * Ruang kerja tim (mis. Room Archipelago) — konteks sebelum Kanban.
 */
model Room {
  id                  String                   @id @default(cuid())
  name                String
  /**
   * Banner visual ruangan (path publik di /uploads/rooms/{roomId}/...).
   */
  bannerImage         String?
  /**
   * Logo persegi ruangan (path publik di /uploads/rooms/{roomId}/logos/...).
   */
  logoImage           String?
  /**
   * Bagian di menu Tugas: HQ, Team, atau Ruangan.
   */
  workspaceSection    RoomWorkspaceSection     @default(ROOMS)
  brandId             String?
  brand               Brand?                   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  projects            Project[]
  messages            RoomMessage[]
  channels            RoomChannel[]
  documents           RoomDocument[]
  documentFolders     RoomDocumentFolder[]
  members             RoomMember[]
  contentPlanItems    RoomContentPlanItem[]
  /**
   * Judul & urutan kolom Kanban per fase proses (diatur manager ruangan).
   */
  kanbanColumns       RoomKanbanColumn[]
  taskTags            TaskTag[]
  /**
   * View tambahan kustom yang ditambahkan oleh manager ruangan
   * (Kalender, Linimasa, Wiki, Hub tautan, List generik, Glosarium).
   */
  views               RoomView[]
  /**
   * Semua fase proses tugas di ruangan (bawaan + tambahan).
   */
  customProcessPhases RoomCustomProcessPhase[]
}

/**
 * Fase proses per ruangan. Fase bawaan punya `legacyProcessKey` (enum awal);
 * fase tambahan dibuat manager dengan `legacyProcessKey` kosong.
 */
model RoomCustomProcessPhase {
  id               String           @id @default(cuid())
  roomId           String
  room             Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name             String           @db.VarChar(80)
  sortOrder        Int              @default(0)
  /**
   * Jika diisi, fase ini mewakili template bawaan (`RoomTaskProcess`) untuk ruangan ini.
   */
  legacyProcessKey RoomTaskProcess?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tasks         Task[]
  kanbanColumns RoomKanbanColumn[]

  @@unique([roomId, legacyProcessKey])
  @@index([roomId, sortOrder])
}

/**
 * View tambahan opsional di ruangan. Manager ruangan dapat menambahkan
 * salah satu jenis view yang tersedia (lihat `RoomViewType`) dengan judul
 * kustom. Setiap view memiliki data sendiri di model anak yang sesuai.
 */
model RoomView {
  id        String       @id @default(cuid())
  roomId    String
  room      Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  type      RoomViewType
  title     String       @db.VarChar(80)
  /**
   * Subjudul / deskripsi singkat (tampil sebagai meta di header view).
   */
  subtitle  String?      @db.VarChar(160)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  calendarEvents     RoomCalendarEvent[]
  timelineMilestones RoomTimelineMilestone[]
  wikiPages          RoomWikiPage[]
  links              RoomLinkItem[]
  listColumns        RoomListColumn[]
  listRows           RoomListRow[]
  glossaryEntries    RoomGlossaryEntry[]

  @@index([roomId, sortOrder])
}

/**
 * Event/acara di view CALENDAR per ruangan.
 */
model RoomCalendarEvent {
  id          String    @id @default(cuid())
  viewId      String
  view        RoomView  @relation(fields: [viewId], references: [id], onDelete: Cascade)
  title       String    @db.VarChar(160)
  description String?
  location    String?   @db.VarChar(200)
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean   @default(false)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([viewId, startsAt])
}

/**
 * Milestone di view TIMELINE per ruangan.
 */
model RoomTimelineMilestone {
  id          String             @id @default(cuid())
  viewId      String
  view        RoomView           @relation(fields: [viewId], references: [id], onDelete: Cascade)
  title       String             @db.VarChar(160)
  description String?
  date        DateTime
  status      RoomTimelineStatus @default(UPCOMING)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([viewId, date])
}

/**
 * Halaman wiki / catatan keputusan di view WIKI per ruangan.
 */
model RoomWikiPage {
  id          String   @id @default(cuid())
  viewId      String
  view        RoomView @relation(fields: [viewId], references: [id], onDelete: Cascade)
  title       String   @db.VarChar(160)
  /**
   * Konten halaman dalam markdown sederhana.
   */
  content     String   @default("")
  sortOrder   Int      @default(0)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([viewId, sortOrder])
}

/**
 * Item tautan di view LINKS per ruangan (hub of links).
 */
model RoomLinkItem {
  id          String   @id @default(cuid())
  viewId      String
  view        RoomView @relation(fields: [viewId], references: [id], onDelete: Cascade)
  title       String   @db.VarChar(160)
  url         String   @db.VarChar(800)
  description String?
  /**
   * Kategori bebas (mis. "Design", "Marketplace") untuk pengelompokan.
   */
  category    String?  @db.VarChar(80)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([viewId, sortOrder])
}

/**
 * Definisi kolom kustom untuk view LIST generik.
 */
model RoomListColumn {
  id        String             @id @default(cuid())
  viewId    String
  view      RoomView           @relation(fields: [viewId], references: [id], onDelete: Cascade)
  /**
   * Identifier stabil (slug), dipakai sebagai key di `RoomListRow.data`.
   */
  key       String             @db.VarChar(40)
  label     String             @db.VarChar(80)
  type      RoomListColumnType @default(TEXT)
  /**
   * Pilihan opsi untuk kolom bertipe SELECT (string array, dinormalisasi).
   */
  options   String[]           @default([])
  sortOrder Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([viewId, key])
  @@index([viewId, sortOrder])
}

/**
 * Baris data untuk view LIST generik (nilai per kolom disimpan di JSON).
 */
model RoomListRow {
  id        String   @id @default(cuid())
  viewId    String
  view      RoomView @relation(fields: [viewId], references: [id], onDelete: Cascade)
  /**
   * Map dari `RoomListColumn.key` → nilai (string/number/bool/date ISO).
   */
  data      Json     @default("{}")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([viewId, sortOrder])
}

/**
 * Entri istilah pada view GLOSSARY per ruangan.
 */
model RoomGlossaryEntry {
  id         String   @id @default(cuid())
  viewId     String
  view       RoomView @relation(fields: [viewId], references: [id], onDelete: Cascade)
  term       String   @db.VarChar(120)
  definition String
  examples   String?
  /**
   * Tag bebas, dinormalisasi di aplikasi (lowercase).
   */
  tags       String[] @default([])
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([viewId, term])
}

/**
 * Kolom Kanban: judul tampilan, urutan, dan pemetaan ke `Task.status` (bucket).
 * CORE = 4 kolom inti (To-Do, Berjalan, Overdue, Selesai); CUSTOM = bebas nama.
 */
model RoomKanbanColumn {
  id                   String                  @id @default(cuid())
  roomId               String
  room                 Room                    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /**
   * Kolom fase enum bawaan — null jika kolom milik fase kustom.
   */
  roomProcess          RoomTaskProcess?
  customProcessPhaseId String?
  customProcessPhase   RoomCustomProcessPhase? @relation(fields: [customProcessPhaseId], references: [id], onDelete: Cascade)
  kind                 KanbanColumnKind        @default(CUSTOM)
  /**
   * Peran kolom inti — hanya untuk `kind = CORE` (max 1 per fase per role).
   */
  coreRole             TaskStatus?
  /**
   * Bucket `Task.status` saat tugas di kolom ini (CORE: sama dengan coreRole; CUSTOM: workflow bucket).
   */
  linkedStatus         TaskStatus
  title                String
  /** Warna aksen kolom (hex). Null = warna default menurut status. */
  colorHex             String?
  sortOrder            Int                     @default(0)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  tasks                Task[]
  kanbanPositions      TaskKanbanPosition[]

  @@unique([roomId, roomProcess, customProcessPhaseId, coreRole])
  @@index([roomId, roomProcess, sortOrder])
  @@index([roomId, customProcessPhaseId, sortOrder])
}

/**
 * Baris content planning per ruangan (tabel kolom lengkap).
 */
model RoomContentPlanItem {
  id                   String                 @id @default(cuid())
  roomId               String
  room                 Room                   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  konten               String                 @default("")
  jenisKonten          ContentPlanJenis       @default(REELS)
  usage                ContentPlanUsage       @default(AWARENESS)
  detailKonten         String?
  copywritingFilePath  String?
  copywritingLink      String?
  /**
   * Beberapa file design (mis. slide carousel); urutan = urutan tayang.
   */
  designFilePaths      String[]               @default([])
  designLink           String?
  picUserId            String?
  /**
   * Multi PIC (utama pakai ini). `picUserId` dipertahankan untuk kompatibilitas data lama.
   */
  picUserIds           String[]               @default([])
  pic                  User?                  @relation("ContentPlanItemPic", fields: [picUserId], references: [id], onDelete: SetNull)
  statusCopywriting    ContentPlanStatusKerja @default(BARU)
  statusDesign         ContentPlanStatusKerja @default(BARU)
  deadlineCopywriting  DateTime?
  deadlineDesign       DateTime?
  tanggalPosting       DateTime?
  catatan              String?
  sortOrder            Int                    @default(0)
  createdById          String
  createdBy            User                   @relation("ContentPlanItemCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  tasksFromContentPlan Task[]
}

model RoomMember {
  id                           String            @id @default(cuid())
  roomId                       String
  room                         Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId                       String
  user                         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                         RoomMemberRole
  /**
   * Fase tugas yang boleh diakses (manager & kontributor). Kosong untuk `ROOM_PROJECT_MANAGER` (diabaikan).
   */
  allowedRoomProcesses         RoomTaskProcess[] @default([])
  /**
   * Fase proses kustom ruangan yang boleh diakses (selain enum bawaan).
   */
  allowedCustomProcessPhaseIds String[]          @default([])
  createdAt                    DateTime          @default(now())
  updatedAt                    DateTime          @updatedAt

  @@unique([roomId, userId])
}

model RoomMessage {
  id          String                  @id @default(cuid())
  roomId      String
  room        Room                    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /**
   * Channel (ala Discord) tempat pesan berada. Nullable untuk kompatibilitas
   * data lama; selalu diisi oleh aplikasi (backfill ke channel default #umum).
   */
  channelId   String?
  channel     RoomChannel?            @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId    String
  author      User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body        String                  @default("")
  /**
   * URL gambar/GIF ter-hosting (Tenor, Giphy, dll.) — teks opsional di `body`.
   */
  gifUrl      String?
  replyToId   String?
  replyTo     RoomMessage?            @relation("RoomMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     RoomMessage[]           @relation("RoomMessageReplies")
  editedAt    DateTime?
  deletedAt   DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @default(now()) @updatedAt
  attachments RoomMessageAttachment[]

  @@index([roomId, createdAt])
  @@index([roomId, updatedAt])
  @@index([channelId, createdAt])
  @@index([channelId, updatedAt])
  @@index([replyToId])
}

/**
 * Channel chat (ala Discord) di dalam sebuah ruangan. Satu ruangan punya satu
 * channel default `#umum` (`isDefault`, tidak dapat dihapus) + channel tambahan
 * yang dibuat manager ruangan.
 */
model RoomChannel {
  id        String            @id @default(cuid())
  roomId    String
  room      Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name      String            @db.VarChar(80)
  topic     String?           @db.VarChar(200)
  sortOrder Int               @default(0)
  isDefault Boolean           @default(false)
  /** Channel terkunci tidak dapat dihapus (selain channel default yang selalu terkunci). */
  isLocked  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  messages  RoomMessage[]
  reads     RoomChannelRead[]

  @@index([roomId, sortOrder])
}

/**
 * Penanda pesan terakhir dibaca per (user, channel) untuk badge unread.
 */
model RoomChannelRead {
  id         String      @id @default(cuid())
  channelId  String
  channel    RoomChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime?
  updatedAt  DateTime    @updatedAt

  @@unique([channelId, userId])
  @@index([userId])
}

model RoomMessageAttachment {
  id         String      @id @default(cuid())
  messageId  String
  message    RoomMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName   String
  mimeType   String
  sizeBytes  Int
  publicPath String
  createdAt  DateTime    @default(now())

  @@index([messageId])
}

/**
 * Percakapan pribadi 1:1 antar pengguna.
 */
model DirectConversation {
  id            String                     @id @default(cuid())
  lastMessageAt DateTime?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  members       DirectConversationMember[]
  messages      DirectMessage[]

  @@index([lastMessageAt(sort: Desc)])
}

model DirectConversationMember {
  id             String             @id @default(cuid())
  conversationId String
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  joinedAt       DateTime           @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model DirectMessage {
  id             String                    @id @default(cuid())
  conversationId String
  conversation   DirectConversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String
  author         User                      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body           String                    @default("")
  gifUrl         String?
  replyToId      String?
  replyTo        DirectMessage?            @relation("DirectMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        DirectMessage[]           @relation("DirectMessageReplies")
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @default(now()) @updatedAt
  attachments    DirectMessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([conversationId, updatedAt])
  @@index([replyToId])
}

model DirectMessageAttachment {
  id         String        @id @default(cuid())
  messageId  String
  message    DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName   String
  mimeType   String
  sizeBytes  Int
  publicPath String
  createdAt  DateTime      @default(now())

  @@index([messageId])
}

/**
 * Folder logis untuk mengelompokkan dokumen bersama per ruangan (Logo, Legal, dll.).
 */
model RoomDocumentFolder {
  id        String               @id @default(cuid())
  roomId    String
  room      Room                 @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /**
   * Folder bersarang (mirip Google Drive). Null = folder di root drive ruangan.
   */
  parentId  String?
  parent    RoomDocumentFolder?  @relation("RoomDocumentFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  RoomDocumentFolder[] @relation("RoomDocumentFolderTree")
  name      String
  sortOrder Int                  @default(0)
  createdAt DateTime             @default(now())
  documents RoomDocument[]

  @@unique([roomId, parentId, name])
  @@index([roomId, parentId, sortOrder])
}

model RoomDocument {
  id           String              @id @default(cuid())
  roomId       String
  room         Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  folderId     String?
  folder       RoomDocumentFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  uploadedById String
  uploadedBy   User                @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  title        String?
  fileName     String
  mimeType     String
  size         Int
  /**
   * Path publik, mis. /uploads/rooms/{roomId}/...
   */
  publicPath   String
  /**
   * Path thumbnail (webp ~480px) untuk grid/list — dibuat saat upload via
   * `sharp`. Null untuk file yang bukan gambar atau saat dekode gagal.
   * UI fallback ke `publicPath` (atau ikon tipe file) bila null.
   */
  thumbPath    String?
  /**
   * Tag bebas (mis. footage, draft, approved) — dinormalisasi di aplikasi.
   */
  tags         String[]            @default([])
  createdAt    DateTime            @default(now())
  comments     RoomDocumentComment[]

  @@index([roomId, folderId])
  /**
   * Halaman dokumen mengurutkan `createdAt desc` setelah filter `roomId`.
   * Index komposit ini membuat query tidak perlu sort di memori.
   */
  @@index([roomId, createdAt(sort: Desc)])
  /**
   * Untuk daftar di dalam folder spesifik (filter `roomId + folderId` lalu
   * sort terbaru), composite ini mempercepat pemilihan halaman.
   */
  @@index([roomId, folderId, createdAt(sort: Desc)])
}

model RoomDocumentComment {
  id           String       @id @default(cuid())
  documentId   String
  document     RoomDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  authorId     String
  author       User         @relation("RoomDocumentCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  assigneeId   String?
  assignee     User?        @relation("RoomDocumentCommentAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  body         String
  selectedText String?
  anchorPage   Int?
  anchorJson   String?      @db.Text
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([documentId, createdAt])
  @@index([assigneeId, resolvedAt])
}

model Project {
  id                       String             @id @default(cuid())
  roomId                   String
  room                     Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /**
   * Kosong untuk papan tugas internal ruangan HQ/Team tanpa brand.
   */
  brandId                  String?
  brand                    Brand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  name                     String
  currentStage             PipelineStage      @default(MARKET_RESEARCH)
  stageEnteredAt           DateTime           @default(now())
  /**
   * Tahap tujuan yang diajukan tim — `currentStage` tidak berubah sampai CEO menyetujui.
   */
  pendingPipelineStage     PipelineStage?
  pipelineStageRequestedAt DateTime?
  totalProgress            Int                @default(0)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  tasks                    Task[]
  milestones               ProjectMilestone[]
}

/**
 * Milestone linimasa per proyek pipeline (template default + kustom).
 */
model ProjectMilestone {
  id          String             @id @default(cuid())
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      ProjectMilestone?  @relation("ProjectMilestoneTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    ProjectMilestone[] @relation("ProjectMilestoneTree")
  title       String             @db.VarChar(200)
  description String?
  status      RoomTimelineStatus @default(UPCOMING)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([projectId, parentId, sortOrder])
}

model Task {
  id                       String                  @id @default(cuid())
  projectId                String
  project                  Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /**
   * Fase alur di ruangan kerja (filter Kanban/List/Gantt per proses).
   * Untuk tugas di fase kustom, tetap diisi default enum; filter pakai `customProcessPhaseId`.
   */
  roomProcess              RoomTaskProcess         @default(MARKET_RESEARCH)
  customProcessPhaseId     String?
  customProcessPhase       RoomCustomProcessPhase? @relation(fields: [customProcessPhaseId], references: [id], onDelete: SetNull)
  title                    String
  description              String?
  status                   TaskStatus              @default(TODO)
  /**
   * Posisi kartu di papan Kanban (kolom aktif untuk room/fase).
   */
  kanbanColumnId           String?
  kanbanColumn             RoomKanbanColumn?       @relation(fields: [kanbanColumnId], references: [id], onDelete: Restrict)
  priority                 TaskPriority            @default(MEDIUM)
  dueDate                  DateTime?
  isApprovalRequired       Boolean                 @default(false)
  isApproved               Boolean                 @default(false)
  vendorId                 String?
  vendor                   Vendor?                 @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  leadTimeDays             Int?
  sortOrder                Int                     @default(0)
  /**
   * Pengingat WA “3 hari lagi” sudah dikirim (hindari duplikat).
   */
  whatsappReminder3dSentAt DateTime?
  /**
   * Pengingat WA “1 hari lagi” sudah dikirim.
   */
  whatsappReminder1dSentAt DateTime?
  /**
   * Tugas selesai diarsipkan — disembunyikan dari papan utama.
   */
  archivedAt               DateTime?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  checklistItems           TaskChecklistItem[]
  comments                 TaskComment[]
  attachments              TaskAttachment[]
  kanbanPositions          TaskKanbanPosition[]
  assignees                TaskAssignee[]
  tags                     TaskTagOnTask[]
  /**
   * Jika diisi, tugas ini dibuat dari baris Content Planning (alur upload khusus).
   */
  contentPlanItemId        String?
  contentPlanItem          RoomContentPlanItem?    @relation(fields: [contentPlanItemId], references: [id], onDelete: SetNull)
  contentPlanJenis         ContentPlanJenis?

  @@index([projectId, roomProcess, archivedAt, sortOrder])
  @@index([projectId, customProcessPhaseId, archivedAt, sortOrder])
  @@index([projectId, archivedAt, status])
  @@index([projectId, createdAt])
  @@index([contentPlanItemId])
  @@index([kanbanColumnId])
}

model TaskTag {
  id        String          @id @default(cuid())
  roomId    String
  room      Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name      String
  colorHex  String          @db.VarChar(7)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tasks     TaskTagOnTask[]

  @@unique([roomId, name])
  @@index([roomId, createdAt])
}

model TaskTagOnTask {
  taskId String
  task   Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    TaskTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

model TaskAssignee {
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([taskId, userId])
  @@index([userId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
}

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String
  size         Int
  /**
   * Path publik untuk unggahan file, mis. /uploads/tasks/{taskId}/...
   */
  publicPath   String?
  /**
   * Tautan eksternal (Drive, Figma, dll.); jika terisi, tidak ada berkas di disk.
   */
  linkUrl      String?
  createdAt    DateTime @default(now())
  comments     TaskAttachmentComment[]

  @@index([taskId, createdAt])
}

/**
 * Urutan manual kartu Kanban per kolom. `sortKey` lebih kecil = lebih atas.
 */
model TaskKanbanPosition {
  taskId    String
  task      Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  columnId  String
  column    RoomKanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  sortKey   Float            @default(0)
  updatedAt DateTime         @updatedAt

  @@id([taskId, columnId])
  @@index([columnId, sortKey])
}

model TaskAttachmentComment {
  id           String         @id @default(cuid())
  attachmentId String
  attachment   TaskAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  authorId     String
  author       User           @relation("TaskAttachmentCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  /**
   * Anggota tim yang ditugaskan menanggapi / menyelesaikan komentar ini.
   */
  assigneeId   String?
  assignee     User?          @relation("TaskAttachmentCommentAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  body         String
  /**
   * Kutipan teks yang dikomentari (Google Drive-style).
   */
  selectedText String?
  /**
   * Halaman PDF (1-based) bila komentar terikat area halaman.
   */
  anchorPage   Int?
  /**
   * JSON anchor: offset teks, rect normalisasi (0–1), jenis (text|region).
   */
  anchorJson   String?        @db.Text
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([attachmentId, createdAt])
  @@index([assigneeId, resolvedAt])
}

model TaskChecklistItem {
  id        String  @id @default(cuid())
  taskId    String
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean @default(false)
  sortOrder Int     @default(0)

  @@index([taskId, sortOrder])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  /**
   * Bell notifikasi melakukan polling per ~45 detik dengan query
   * `where userId order by createdAt desc take 40`. Index komposit ini
   * mengubahnya jadi index-only scan dan menghilangkan sort runtime.
   */
  @@index([userId, createdAt(sort: Desc)])
  /**
   * Hitungan unread (`where userId AND isRead=false`) — partial index akan
   * lebih hemat lagi, tapi Prisma belum mendukungnya secara native; index
   * komposit biasa sudah cukup baik untuk kardinalitas yang ada.
   */
  @@index([userId, isRead])
}

model Vendor {
  id                      String                   @id @default(cuid())
  name                    String
  picName                 String?
  contact                 String?
  specialty               String?
  /**
   * Hari dari PO dikirim sampai barang masuk gudang (lead time maklon).
   */
  leadTimeDays            Int?
  /**
   * Buffer demand dalam hari untuk safety stock (default 7).
   */
  safetyStockDays         Int                      @default(7)
  /**
   * Siklus review pemesanan ulang dalam hari (default 14).
   */
  reviewPeriodDays        Int                      @default(14)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  tasks                   Task[]
  financeApBills          FinanceApBill[]
  financeJournalLineLinks FinanceJournalLineLink[]
  stockLogs               StockLog[]
  preferredByProducts     Product[]                @relation("ProductPreferredVendor")
  productLinks            ProductVendor[]
}

model Product {
  id                String        @id @default(cuid())
  brandId           String
  brand             Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name              String
  sku               String        @unique
  currentStock      Int           @default(0)
  minStock          Int           @default(0)
  category          String?
  pipelineStage     PipelineStage @default(MARKET_RESEARCH)
  preferredVendorId       String?
  preferredVendor         Vendor?       @relation("ProductPreferredVendor", fields: [preferredVendorId], references: [id], onDelete: SetNull)
  /**
   * Override lead time per SKU (hari). Jika null, pakai vendor.leadTimeDays.
   */
  leadTimeDaysOverride    Int?
  /**
   * Override safety stock buffer per SKU (hari demand). Jika null, pakai vendor.safetyStockDays.
   */
  safetyStockDaysOverride Int?
  createdAt               DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  stockLogs         StockLog[]
  productVendors    ProductVendor[]

  @@index([brandId])
  @@index([preferredVendorId])
}

/**
 * Vendor dalam rantai pasok SKU — satu produk bisa punya beberapa vendor (botol, packaging, maklon).
 */
model ProductVendor {
  id                   String            @id @default(cuid())
  productId            String
  product              Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendorId             String
  vendor               Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  role                 ProductVendorRole @default(MAKLON)
  /**
   * Label kustom jika role OTHER.
   */
  roleLabel            String?
  /**
   * Override lead time untuk rantai vendor ini (hari).
   */
  leadTimeDaysOverride Int?
  sortOrder            Int               @default(0)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@unique([productId, vendorId, role])
  @@index([productId])
  @@index([vendorId])
}

model StockLog {
  id            String       @id @default(cuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  amount        Int
  type          StockLogType
  /**
   * Kategori penjualan saat barang keluar (contoh: marketplace, reseller, retail).
   */
  salesCategory String?
  note          String?
  /**
   * Referensi eksternal: nomor PO, invoice, batch produksi, dll.
   */
  reference     String?
  vendorId      String?
  vendor        Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?        @relation("StockLogCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())

  /**
   * Dashboard executive memfilter `type = OUT` dengan window 90 hari terakhir.
   * Index komposit ini membuat query langsung skip baris yang tidak relevan.
   */
  @@index([type, createdAt(sort: Desc)])
  @@index([productId, createdAt(sort: Desc)])
  @@index([vendorId])
}

/**
 * Jadwal umum (meeting, acara) — tidak terikat ruangan.
 */
model ScheduleEvent {
  id              String                     @id @default(cuid())
  title           String
  description     String?
  location        String?
  startsAt        DateTime
  recurrence      ScheduleRecurrence         @default(NONE)
  recurrenceUntil DateTime?
  seriesId        String?
  createdById     String
  createdBy       User                       @relation("ScheduleEventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  participants    ScheduleEventParticipant[]
  remindersSent   ScheduleReminderSent[]

  @@index([startsAt])
  @@index([seriesId, startsAt])
}

model ScheduleEventParticipant {
  id      String        @id @default(cuid())
  eventId String
  event   ScheduleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

model ScheduleReminderSent {
  id      String               @id @default(cuid())
  eventId String
  event   ScheduleEvent        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind    ScheduleReminderKind
  sentAt  DateTime             @default(now())

  @@unique([eventId, userId, kind])
  @@index([eventId])
}

/**
 * Konfigurasi branding aplikasi (singleton).
 */
model AppBranding {
  id            String   @id
  appName       String   @default("Dominatus Control Center")
  navTitle      String   @default("Dominatus")
  navSubtitle   String   @default("Control Center")
  logoImagePath String?
  faviconPath   String?
  /**
   * Icon untuk web push notification (chat, dsb).
   */
  pushIconPath  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- Modul keuangan (Finance) ---

enum FinanceLedgerType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum FinanceJournalStatus {
  DRAFT
  POSTED
}

enum FinanceApArDocStatus {
  OPEN
  PARTIAL
  PAID
  VOID
}

enum FinanceSpendRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum FinanceDepreciationMethod {
  STRAIGHT_LINE
}

model FinanceLedgerAccount {
  id             String                 @id @default(cuid())
  code           String                 @unique
  name           String
  type           FinanceLedgerType
  parentId       String?
  parent         FinanceLedgerAccount?  @relation("CoaHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       FinanceLedgerAccount[] @relation("CoaHierarchy")
  isActive       Boolean                @default(true)
  sortOrder      Int                    @default(0)
  /**
   * Untuk laporan arus kas (Kas, Bank, e-wallet operasional).
   */
  tracksCashflow Boolean                @default(false)
  /**
   * Menandai akun "Hutang Usaha" (AP control). Saat akun dengan flag ini dipilih
   * pada baris jurnal, form akan menampilkan field tambahan untuk membuat tagihan
   * baru atau melunasi tagihan yang ada.
   */
  isApControl    Boolean                @default(false)
  /**
   * Menandai akun "Piutang Usaha" (AR control). Sama seperti `isApControl`
   * tetapi untuk invoice ke pelanggan.
   */
  isArControl    Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  journalLines         FinanceJournalLine[]
  bankAccounts         FinanceBankAccount[]
  budgetLines          FinanceBudgetLine[]
  fixedAssetsAsset     FinanceFixedAsset[]   @relation("FaAssetCoa")
  fixedAssetsAccum     FinanceFixedAsset[]   @relation("FaAccumCoa")
  fixedAssetsExpense   FinanceFixedAsset[]   @relation("FaExpenseCoa")
