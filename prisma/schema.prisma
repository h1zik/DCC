  status         UspGapStatus    @default(PENDING)
  errorMessage   String?
  createdById    String
  createdBy      User            @relation("BrandUspAnalysisCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  result         BrandUspResult?

  @@index([createdById])
  @@index([status])
  @@index([ownerBrandId])
}

model BrandUspResult {
  id                   String           @id @default(cuid())
  analysisId           String           @unique
  analysis             BrandUspAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  gapMatrix            Json             @default("[]")
  claimAnalysis        Json             @default("{}")
  positioningMap       Json             @default("{}")
  uspCandidates        Json             @default("[]")
  differentiationScore Float?
  aiSummary            String?          @db.Text
  aiActionPlan         Json?
  categoryDecision     Json?
  aiMeta               Json?
  updatedAt            DateTime         @updatedAt
}

model BrandResearchScrapeJob {
  id          String                  @id @default(cuid())
  type        ResearchScrapeJobType
  entityId    String
  apifyRunId  String?
  status      ResearchScrapeJobStatus @default(PENDING)
  error       String?                 @db.Text
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime                @default(now())
  stepLabel   String?
  percent     Int                     @default(0)
  currentStep Int?
  totalSteps  Int?

  @@index([status])
  @@index([entityId, type])
  @@index([apifyRunId])
}

enum BrandVisualAssetSource {
  PINTEREST
  COMPETITOR_LISTING
  SOCIAL
  META_AD
  MANUAL
}

enum BrandVisualCollectionStatus {
  PENDING
  COLLECTING
  READY
  FAILED
}

enum BrandStrategyStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

enum BrandCreativeGuidelineStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

model BrandVisualCollection {
  id                String                      @id @default(cuid())
  name              String
  keywords          String[]                    @default([])
  maxPinsPerKeyword Int?
  status            BrandVisualCollectionStatus @default(PENDING)
  sourceConfig      Json?
  errorMessage      String?
  ownerBrandId      String?
  ownerBrand        Brand?                      @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  createdById       String
  createdBy         User                        @relation("BrandVisualCollectionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  assets            BrandVisualAsset[]

  @@index([createdById])
  @@index([ownerBrandId])
  @@index([status])
}

model BrandVisualAsset {
  id             String                 @id @default(cuid())
  collectionId   String?
  collection     BrandVisualCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  ownerBrandId   String?
  ownerBrand     Brand?                 @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  source         BrandVisualAssetSource
  imageUrl       String
  thumbnailUrl   String?
  title          String?
  description    String?                @db.Text
  sourceUrl      String?
  externalId     String?
  tags           String[]               @default([])
  aestheticTags  String[]               @default([])
  dominantColors Json?
  metadata       Json?
  createdAt      DateTime               @default(now())

  @@unique([collectionId, source, externalId])
  @@index([collectionId])
  @@index([ownerBrandId])
  @@index([source])
}

enum BrandPortfolioLineRole {
  HERO
  CORE
  FLANKER
  EXPERIMENTAL
}

/**
 * Planned product lines for a brand — input utama sebelum Brand Strategy.
 */
model BrandPortfolio {
  id          String               @id @default(cuid())
  brandId     String               @unique
  brand       Brand                @relation(fields: [brandId], references: [id], onDelete: Cascade)
  summary     String?              @db.Text
  createdById String
  createdBy   User                 @relation("BrandPortfolioCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  lines       BrandPortfolioLine[]

  @@index([createdById])
}

model BrandPortfolioLine {
  id                      String                  @id @default(cuid())
  portfolioId             String
  portfolio               BrandPortfolio          @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  sortOrder               Int                     @default(0)
  name                    String
  category                String?
  description             String?                 @db.Text
  targetAudience          String?
  role                    BrandPortfolioLineRole?
  productDiscoveryQueryId String?
  productDiscoveryQuery   ProductDiscoveryQuery?  @relation(fields: [productDiscoveryQueryId], references: [id], onDelete: SetNull)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([portfolioId])
  @@index([productDiscoveryQueryId])
}

model BrandStrategyDocument {
  id                  String                   @id @default(cuid())
  ownerBrandId        String?
  ownerBrand          Brand?                   @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  version             Int                      @default(1)
  status              BrandStrategyStatus      @default(DRAFT)
  /**
   * Per-line messaging & role from portfolio synthesis.
   */
  productLineStrategy Json                     @default("[]")
  /**
   * Product/category context for strategy (e.g. skincare, body care).
   */
  category            String?
  /**
   * PM creative brief / constraints fed to AI at generation.
   */
  pmBrief             String?                  @db.Text
  brandPurpose        String?                  @db.Text
  brandEssence        String?                  @db.Text
  coreMessage         String?                  @db.Text
  brandUsp            String?                  @db.Text
  stp                 Json?
  brandPersonality    Json?
  toneOfVoice         Json?
  /**
   * Tension pairs the brand must navigate (from insight step).
   */
  strategicTensions   Json                     @default("[]")
  /**
   * Step-1 insight memo (audit + input to strategy synthesis).
   */
  insightMemo         Json?
  /**
   * Prescriptive action plan for cross-functional teams.
   */
  actionPlan          Json?
  /**
   * Citation validation score + invalid ref details.
   */
  citationQuality     Json?
  evidenceRefs        Json                     @default("[]")
  /**
   * User-selected modules/entities fed to AI at generation time.
   */
  generationConfig    Json                     @default("{}")
  /**
   * Per-field detailed reasoning from AI generation.
   */
  strategyRationales  Json                     @default("[]")
  /**
   * Deterministic input fed to AI at generation time (audit trail).
   */
  evidenceSnapshot    Json                     @default("{}")
  aiMeta              Json?
  errorMessage        String?
  createdById         String
  createdBy           User                     @relation("BrandStrategyDocumentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  creativeGuidelines  BrandCreativeGuideline[]

  @@index([createdById])
  @@index([ownerBrandId])
  @@index([status])
}

/**
 * Audience Persona & Motivation — sintesis AI atas voice-of-customer brand
 * (review intel, social listening, ad library, keyword intel) menjadi 2-4
 * persona target market dengan pain point, harapan, motivasi, dan kebiasaan beli.
 */
model BrandAudienceProfile {
  id               String              @id @default(cuid())
  ownerBrandId     String?
  ownerBrand       Brand?              @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  version          Int                 @default(1)
  status           BrandAudienceStatus @default(DRAFT)
  /**
   * Konteks kategori produk (mis. parfum, skincare).
   */
  category         String?
  /**
   * Brief/constraint PM yang diumpankan ke AI saat generate.
   */
  pmBrief          String?             @db.Text
  /**
   * Array persona: tiap item { name, archetype, demographics, painPoints[],
   * hopes[], motivations{functional[],emotional[],social[]},
   * habits{channels[],triggers[],buyingBehavior,decisionFactors[]},
   * representativeQuotes[], shareOfAudience? }.
   */
  personas         Json                @default("[]")
  /**
   * Ringkasan lintas-persona untuk brand.
   */
  aiSummary        String?             @db.Text
  /**
   * Implikasi messaging/produk yang actionable.
   */
  actionPlan       Json?
  /**
   * Modul/entitas yang dipilih saat generate.
   */
  generationConfig Json                @default("{}")
  /**
   * Input deterministik yang diumpankan ke AI (audit trail).
   */
  evidenceSnapshot Json                @default("{}")
  evidenceRefs     Json                @default("[]")
  aiMeta           Json?
  errorMessage     String?
  createdById      String
  createdBy        User                @relation("BrandAudienceProfileCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([createdById])
  @@index([ownerBrandId])
  @@index([status])
}

enum BrandAudienceStatus {
  DRAFT
  GENERATING
  READY
  FAILED
}

model BrandCreativeGuideline {
  id                 String                       @id @default(cuid())
  strategyDocumentId String?
  strategyDocument   BrandStrategyDocument?       @relation(fields: [strategyDocumentId], references: [id], onDelete: SetNull)
  ownerBrandId       String?
  ownerBrand         Brand?                       @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  status             BrandCreativeGuidelineStatus @default(PENDING)
  moodboardAssetIds  Json                         @default("[]")
  colorPalette       Json?
  typography         Json?
  designReferences   Json                         @default("[]")
  aiSummary          String?                      @db.Text
  aiMeta             Json?
  errorMessage       String?
  createdById        String
  createdBy          User                         @relation("BrandCreativeGuidelineCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([createdById])
  @@index([ownerBrandId])
  @@index([strategyDocumentId])
  @@index([status])
}

// ============================================================
// SEO Toolkit
// Modul SEO untuk tim marketing (kosmetik/skincare, pasar Indonesia).
// Melengkapi Research Hub — tidak menggantinya. Default lokasi Indonesia
// (location_code 2360, language_code "id"). Fase 1: Keyword Research &
// Clustering + SERP Rank Tracker. Fase berikutnya menambah audit, crawler,
// backlink, content optimizer, marketplace SEO, dan reports.
// ============================================================

enum SeoJobType {
  KEYWORD_RESEARCH
  RANK_CHECK
  ONPAGE_AUDIT
  SITE_CRAWL
  BACKLINK_FETCH
  MARKETPLACE_SEO
}

enum SeoJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

/**
 * Status siklus analisis SEO (mengikuti pola KeywordIntelStatus).
 */
enum SeoAnalysisStatus {
  PENDING
  COLLECTING
  ANALYZING
  READY
  FAILED
}

/**
 * Intent pencarian keyword (untuk clustering).
 */
enum SeoKeywordIntent {
  INFORMATIONAL
  COMMERCIAL
  TRANSACTIONAL
  NAVIGATIONAL
  UNKNOWN
}

enum SeoRankDevice {
  DESKTOP
  MOBILE
}

/**
 * Cache respons DataForSEO untuk menghemat biaya (mis. 24 jam untuk keyword/SERP).
 * `cacheKey` = hash stabil dari endpoint + payload permintaan.
 */
model DataForSeoCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  endpoint  String
  payload   Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}

/**
 * Job async generik untuk modul SEO (crawler, audit, backlink, rank check).
 * Mengikuti pola `ResearchScrapeJob` — entityId menunjuk ke entitas terkait.
 */
model SeoJob {
  id               String       @id @default(cuid())
  type             SeoJobType
  entityId         String
  status           SeoJobStatus @default(PENDING)
  /**
   * ID task DataForSEO untuk metode standard/queue (bila dipakai).
   */
  dataforseoTaskId String?
  error            String?      @db.Text
  stepLabel        String?
  percent          Int          @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime     @default(now())

  @@index([status])
  @@index([entityId, type])
  @@index([dataforseoTaskId])
}

/**
 * Proyek/daftar keyword yang bisa dipakai ulang. Hasil riset (volume, difficulty,
 * intent, cluster) disimpan per-keyword di `SeoKeyword`.
 */
model SeoKeywordProject {
  id           String               @id @default(cuid())
  name         String
  description  String?
  seedKeyword  String
  marketplace  ResearchMarketplace?
  locationCode Int                  @default(2360)
  languageCode String               @default("id")
  status       SeoAnalysisStatus    @default(PENDING)
  /**
   * Catatan kualitas data (mis. DataForSEO tidak tersedia, dsb.).
   */
  dataNotice   String?              @db.Text
  aiSummary    String?              @db.Text
  /**
   * Metadata model AI yang dipakai saat analisis terakhir.
   */
  aiMeta       Json?
  errorMessage String?
  createdById  String
  createdBy    User                 @relation("SeoKeywordProjectCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  keywords     SeoKeyword[]

  @@index([createdById])
  @@index([status])
}

model SeoKeyword {
  id           String            @id @default(cuid())
  projectId    String
  project      SeoKeywordProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keyword      String
  searchVolume Int?
  cpc          Float?
  /**
   * 0–1, dari competition Google Ads.
   */
  competition  Float?
  /**
   * 0–100, keyword difficulty DataForSEO Labs.
   */
  difficulty   Int?
  intent       SeoKeywordIntent  @default(UNKNOWN)
  clusterLabel String?
  /**
   * SERP features (string[]).
   */
  serpFeatures Json?
  /**
   * Riwayat volume bulanan / arah tren.
   */
  monthlyTrend Json?
  /**
   * Asal data: dataforseo_labs | google_ads | seed.
   */
  source       String?
  createdAt    DateTime          @default(now())

  @@unique([projectId, keyword])
  @@index([projectId, clusterLabel])
}

/**
 * Proyek rank tracking — satu domain target + market. Berisi keyword yang dilacak
 * posisinya di Google ID secara terjadwal (cron harian) → time-series snapshot.
 */
model SeoRankProject {
  id           String              @id @default(cuid())
  name         String
  /**
   * Domain target, mis. "brandanda.com".
   */
  domain       String
  locationCode Int                 @default(2360)
  languageCode String              @default("id")
  device       SeoRankDevice       @default(MOBILE)
  isActive     Boolean             @default(true)
  createdById  String
  createdBy    User                @relation("SeoRankProjectCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  keywords     SeoTrackedKeyword[]

  @@index([createdById])
  @@index([isActive])
}

model SeoTrackedKeyword {
  id               String            @id @default(cuid())
  projectId        String
  project          SeoRankProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  keyword          String
  /**
   * URL/path spesifik yang diharapkan ranking; default cocokkan domain proyek.
   */
  targetUrl        String?
  /**
   * Posisi terakhir (null = di luar top 100).
   */
  lastPosition     Int?
  previousPosition Int?
  lastFoundUrl     String?
  lastCheckedAt    DateTime?
  createdAt        DateTime          @default(now())
  snapshots        SeoRankSnapshot[]

  @@unique([projectId, keyword])
  @@index([projectId])
}

/**
 * Time-series posisi SERP untuk satu tracked keyword.
 */
model SeoRankSnapshot {
  id               String            @id @default(cuid())
  trackedKeywordId String
  trackedKeyword   SeoTrackedKeyword @relation(fields: [trackedKeywordId], references: [id], onDelete: Cascade)
  /**
   * Posisi organik (null = tidak masuk top 100).
   */
  position         Int?
  foundUrl         String?
  /**
   * SERP features yang muncul (string[]).
   */
  serpFeatures     Json?
  capturedAt       DateTime          @default(now())

  @@index([trackedKeywordId, capturedAt])
}

// ============================================================
// SEO Toolkit — Fase 2: On-Page Audit & Technical Crawler
// ============================================================

/**
 * Tingkat keparahan isu SEO (untuk prioritisasi).
 */
enum SeoIssueSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

/**
 * Audit On-Page satu URL: title, meta, heading, alt text, link, word count,
 * schema, readability → skor + rekomendasi actionable (LLM).
 * Sumber data: DataForSEO On-Page `instant_pages` (live) + enrich HTML langsung.
 */
model SeoOnPageAudit {
  id                String            @id @default(cuid())
  url               String
  targetKeyword     String?
  status            SeoAnalysisStatus @default(PENDING)
  /**
   * Skor On-Page 0-100.
   */
  score             Int?
  /**
   * Sinyal terstruktur (title, meta, word count, link, readability, dll).
   */
  signals           Json?
  /**
   * Struktur heading H1-H6.
   */
  headings          Json?
  /**
   * Daftar isu { type, severity, message, recommendation }.
   */
  issues            Json?
  /**
   * Rekomendasi actionable dari LLM (Bahasa Indonesia).
   */
  aiRecommendations Json?
  aiMeta            Json?
  dataNotice        String?           @db.Text
  errorMessage      String?
  createdById       String
  createdBy         User              @relation("SeoOnPageAuditCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([createdById])
  @@index([status])
}

/**
 * Crawl teknis satu domain (DataForSEO On-Page task-based). Hasil: isu broken
 * link, redirect, status code, duplicate/missing meta, sitemap/robots, dan
 * Core Web Vitals (Lighthouse, opsional). Daftar isu di `SeoCrawlIssue`.
 */
model SeoSiteCrawl {
  id                String            @id @default(cuid())
  name              String
  domain            String
  maxPages          Int               @default(100)
  includeLighthouse Boolean           @default(false)
  status            SeoAnalysisStatus @default(PENDING)
  /**
   * ID task DataForSEO On-Page (metode standard/queue).
   */
  dataforseoTaskId  String?
  pagesCrawled      Int               @default(0)
  /**
   * Ringkasan agregat (page_metrics, domain_info).
   */
  summary           Json?
  /**
   * Core Web Vitals (Lighthouse) bila diaktifkan.
   */
  lighthouse        Json?
  dataNotice        String?           @db.Text
  errorMessage      String?
  createdById       String
  createdBy         User              @relation("SeoSiteCrawlCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  issues            SeoCrawlIssue[]

  @@index([createdById])
  @@index([status])
  @@index([dataforseoTaskId])
}

model SeoCrawlIssue {
  id        String           @id @default(cuid())
  crawlId   String
  crawl     SeoSiteCrawl     @relation(fields: [crawlId], references: [id], onDelete: Cascade)
  /**
   * Kategori isu, mis. "broken_links", "duplicate_title", "is_4xx_code".
   */
  type      String
  severity  SeoIssueSeverity
  /**
   * Jumlah halaman / kemunculan (untuk isu agregat).
   */
  count     Int              @default(1)
  /**
   * URL spesifik (untuk isu per-halaman); null untuk isu agregat.
   */
  url       String?
  message   String
  detail    Json?
  createdAt DateTime         @default(now())

  @@index([crawlId, severity])
}

// ============================================================
// SEO Toolkit — Fase 3: Backlink Analysis & Content Optimizer
// ============================================================

/**
 * Profil backlink satu domain/URL (DataForSEO Backlinks API): metrik agregat,
 * top referring domains, anchor text, dan time-series untuk backlink baru/hilang.
 */
model SeoBacklinkProfile {
  id                  String                @id @default(cuid())
  name                String
  /**
   * Domain atau URL target.
   */
  target              String
  status              SeoAnalysisStatus     @default(PENDING)
  /**
   * Metrik agregat { rank, backlinks, referringDomains, dofollow, spamScore, ... }.
   */
  summary             Json?
  /**
   * Top referring domains (array).
   */
  topReferringDomains Json?
  /**
   * Top anchor text (array).
   */
  topAnchors          Json?
  /**
   * Time-series new/lost dari DataForSEO history.
   */
  history             Json?
  dataNotice          String?               @db.Text
  errorMessage        String?
  createdById         String
  createdBy           User                  @relation("SeoBacklinkProfileCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  snapshots           SeoBacklinkSnapshot[]
  gaps                SeoBacklinkGap[]

  @@index([createdById])
  @@index([status])
}

/**
 * Time-series metrik backlink per pengecekan (untuk tren naik/turun).
 */
model SeoBacklinkSnapshot {
  id               String             @id @default(cuid())
  profileId        String
  profile          SeoBacklinkProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  referringDomains Int                @default(0)
  backlinks        Int                @default(0)
  rank             Int?
  capturedAt       DateTime           @default(now())

  @@index([profileId, capturedAt])
}

/**
 * Backlink gap: domain yang menaut ke kompetitor tapi belum ke target.
 */
model SeoBacklinkGap {
  id           String             @id @default(cuid())
  profileId    String
  profile      SeoBacklinkProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  competitor   String
  status       SeoAnalysisStatus  @default(PENDING)
  /**
   * Daftar domain gap [{ domain, rank, backlinks }].
   */
  gapDomains   Json?
  gapCount     Int                @default(0)
  errorMessage String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([profileId])
}

/**
 * Brief artikel SEO dari keyword target — outline + related keywords + angle
 * (LLM, tone kosmetik, Bahasa Indonesia). Menghasilkan satu/lebih draft.
 */
model SeoContentBrief {
  id              String            @id @default(cuid())
  targetKeyword   String
  title           String
  status          SeoAnalysisStatus @default(PENDING)
  /**
   * Related/long-tail keywords yang disarankan (string[]).
   */
  relatedKeywords Json?
  /**
   * Outline artikel [{ heading, points[] }].
   */
  outline         Json?
  /**
   * Catatan angle/strategi (Bahasa Indonesia).
   */
  aiSummary       String?           @db.Text
  aiMeta          Json?
  errorMessage    String?
  createdById     String
  createdBy       User              @relation("SeoContentBriefCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  drafts          SeoContentDraft[]

  @@index([createdById])
  @@index([status])
}

/**
 * Draft artikel (HTML TipTap) + hasil analisis SEO (skor + saran).
 */
model SeoContentDraft {
  id            String           @id @default(cuid())
  briefId       String?
  brief         SeoContentBrief? @relation(fields: [briefId], references: [id], onDelete: SetNull)
  title         String
  targetKeyword String?
  /**
   * Konten HTML dari editor TipTap.
   */
  contentHtml   String           @default("") @db.Text
  /**
   * Hasil analisis { checks[], density, structure, suggestions[] }.
   */
  analysis      Json?
  score         Int?
  aiMeta        Json?
  createdById   String
  createdBy     User             @relation("SeoContentDraftCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([createdById])
  @@index([briefId])
}

// ============================================================
// SEO Toolkit — Fase 4: Marketplace SEO & Reports
// ============================================================

/**
 * Analisis Marketplace SEO: scrape listing teratas untuk satu keyword (via
 * scraper-api VPS), pelajari pola judul/harga/terjual/rating, dan skor optimasi
 * judul produk sendiri + rekomendasi.
 */
model SeoMarketplaceAnalysis {
  id                String              @id @default(cuid())
  keyword           String
  marketplace       ResearchMarketplace
  ownTitle          String?
  status            SeoAnalysisStatus   @default(PENDING)
  /**
   * Statistik listing { count, avgTitleLength, medianPrice, priceRange, avgRating, totalSold, officialShopRate }.
   */
  listingStats      Json?
  /**
   * Top istilah judul [{ term, count }].
   */
  titlePatterns     Json?
  /**
   * Sampel listing teratas.
   */
  topListings       Json?
  optimizationScore Int?
  /**
   * Hasil skor judul sendiri { score, missingTerms[], recommendations[] }.
   */
  recommendations   Json?
  aiMeta            Json?
  dataNotice        String?             @db.Text
  errorMessage      String?
  createdById       String
  createdBy         User                @relation("SeoMarketplaceAnalysisCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([createdById])
  @@index([status])
}

enum SeoReportType {
  OVERVIEW
  RANK_TRACKING
  TECHNICAL
  FULL
}

/**
 * Laporan SEO yang dapat diekspor PDF/DOCX lewat pipeline Research Reports.
 * Mengaggregasi metrik dari rank tracker, audit, crawler, dan backlink.
 */
model SeoReport {
  id           String            @id @default(cuid())
  title        String
  type         SeoReportType     @default(OVERVIEW)
  status       SeoAnalysisStatus @default(PENDING)
  config       Json?
  /**
   * Section laporan [{ id, title, body, moduleRef? }].
   */
  sections     Json?
  aiSummary    String?           @db.Text
  /**
   * Metrik ringkas untuk bar chart.
   */
  metrics      Json?
  aiMeta       Json?
  periodStart  DateTime?
  periodEnd    DateTime?
  errorMessage String?
  createdById  String
  createdBy    User              @relation("SeoReportCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([createdById])
  @@index([status])
}

/**
 * Topic Discovery untuk Content Optimizer: dari satu seed/kategori, tarik
 * keyword ideas + skor opportunity (volume × difficulty × intent × tren) dan
 * usulkan judul/angle ter-grounding SERP (LLM). Mengurangi friksi blank-page.
 */
model SeoContentTopicRun {
  id           String            @id @default(cuid())
  seed         String
  status       SeoAnalysisStatus @default(PENDING)
  /**
   * Saran topik ter-ranking [{ keyword, searchVolume, difficulty, intent, opportunityScore, suggestedTitle, angle, competingTitles[] }].
   */
  suggestions  Json?
  dataNotice   String?           @db.Text
  aiMeta       Json?
  errorMessage String?
  createdById  String
  createdBy    User              @relation("SeoContentTopicRunCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([createdById])
  @@index([status])
}

// ============================================================
// Content & Creator Studio — Fase 1: Ideation (Content Ideas)
// Tools marketing untuk ide konten/caption/hashtag yang GROUNDED ke data nyata
// brand (Review Intel, Ad Library, Trend Radar, Brand Strategy) + feedback loop.
// ============================================================

enum ContentStudioStatus {
  PENDING
  COLLECTING
  ANALYZING
  READY
  FAILED
}

enum ContentIdeaFeedback {
  UP
  DOWN
}

/**
 * Satu sesi generate ide konten untuk satu topik/kampanye (brand-scoped).
 * Ide-nya digrounding ke sinyal nyata brand & dinilai self-critique agar tajam.
 */
model ContentStudioIdeaSet {
  id               String              @id @default(cuid())
  name             String
  ownerBrandId     String?
  ownerBrand       Brand?              @relation(fields: [ownerBrandId], references: [id], onDelete: SetNull)
  topic            String
  goal             String?
  platforms        String[]            @default([])
  status           ContentStudioStatus @default(PENDING)
  /**
   * Sumber grounding yang benar-benar terpakai (transparansi: review/ad/trend/voice).
   */
  groundingSources String[]            @default([])
  dataNotice       String?             @db.Text
  aiSummary        String?             @db.Text
  aiMeta           Json?
  errorMessage     String?
  createdById      String
  createdBy        User                @relation("ContentStudioIdeaSetCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  ideas            ContentStudioIdea[]

  @@index([createdById])
  @@index([ownerBrandId])
  @@index([status])
}

model ContentStudioIdea {
  id           String               @id @default(cuid())
  setId        String
  set          ContentStudioIdeaSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  /**
   * Didenormalisasi dari set agar "winner" bisa diquery cepat per brand untuk few-shot.
   */
  ownerBrandId String?
  title        String
  angle        String               @db.Text
  format       String?
  hook         String?              @db.Text
  platform     String?
  cta          String?
  /**
   * Bukti/citation: sinyal nyata yang mendasari ide — [{ source, text }].
   */
  citations    Json?
  /**
   * Skor "sharpness" 1-100 dari self-critique (anti-generic).
   */
  score        Int?
  /**
   * Feedback adopsi tim → jadi few-shot untuk generasi berikutnya.
   */
  feedback     ContentIdeaFeedback?
  used         Boolean              @default(false)
  createdAt    DateTime             @default(now())

  @@index([setId])
  @@index([ownerBrandId, feedback])
  @@index([ownerBrandId, used])
}

// ─── Profile Gamification (ala Steam) ────────────────────────────────────────
// Semua ADDITIVE & data-driven (katalog via tabel + seed). XP hanya MEMBACA
// sumber riil (Attendance/Task/Finance/Research); tabel di bawah adalah state
// gamifikasi terpisah, hanya di-load/tulis saat `PROFILE_GAMIFICATION_ENABLED`.
// Lihat docs/design/profile-gamification-2026-07-08.md.

enum XpReason {
  ATTENDANCE
  TASK_ONTIME
  DATA_FRESH
  ACHIEVEMENT
  TENURE
}

enum AchievementCategory {
  ATTENDANCE
  TASK
  DATA
  SOCIAL
  MILESTONE
}

enum AchievementTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum CosmeticType {
  PROFILE_BACKGROUND
  AVATAR_BORDER
  NAMEPLATE
  TITLE
  ACCENT
}

enum CosmeticRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum CosmeticUnlockType {
  FREE
  LEVEL
  ACHIEVEMENT
  CUSTOM_UPLOAD
}

enum CosmeticSource {
  DEFAULT
  LEVEL
  ACHIEVEMENT
  UPLOAD
}

/**
 * Progres XP/level seorang User (satu baris per user). Di-recompute idempotent
 * dari `XpLedger`. `level` tidak pernah turun (lantai = level keanggotaan lama).
 */
model UserProgression {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xpTotal                 Int      @default(0)
  level                   Int      @default(1)
  attendanceStreak        Int      @default(0)
  longestAttendanceStreak Int      @default(0)
  /**
   * Hari check-in terakhir, "YYYY-MM-DD" Asia/Jakarta (samakan dgn Attendance.date).
   */
  lastCheckinDate         String?  @db.VarChar(10)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([level])
  @@index([xpTotal])
}

/**
 * Ledger XP append-only: audit + idempotensi. Satu event = satu `dedupeKey`
 * unik (mis. `attendance:<userId>:<date>`, `task_ontime:<taskId>`).
 */
model XpLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    XpReason
  refType   String?  @db.VarChar(32)
  refId     String?  @db.VarChar(64)
  /**
   * KUNCI anti-double-grant.
   */
  dedupeKey String   @unique @db.VarChar(180)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, reason])
}

/**
 * Katalog achievement (data-driven). `criteria` = JSON machine-evaluable, mis.
 * {"type":"attendance_streak","threshold":7}. `unlocksCosmeticKey` = soft-ref
 * ke `CosmeticItem.key` (bukan FK, biar katalog fleksibel).
 */
model Achievement {
  id                 String              @id @default(cuid())
  key                String              @unique @db.VarChar(64)
  name               String              @db.VarChar(120)
  description        String              @db.VarChar(400)
  category           AchievementCategory
  tier               AchievementTier
  icon               String              @db.VarChar(48)
  symbolSrc          String?             @db.VarChar(300)
  symbolMedia        String?             @db.VarChar(16)
  symbolPoster       String?             @db.VarChar(300)
  symbolFileName     String?             @db.VarChar(160)
  xpReward           Int                 @default(0)
  criteria           Json
  unlocksCosmeticKey String?             @db.VarChar(64)
  hidden             Boolean             @default(false)
  isActive           Boolean             @default(true)
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  userAchievements   UserAchievement[]

  @@index([category, tier])
  @@index([isActive])
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  /**
   * Progres menuju threshold (mis. streak berjalan).
   */
  progress      Int         @default(0)
  /**
   * Null = masih tracked/in-progress; terisi = sudah terbuka.
   */
  unlockedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
}

/**
 * Katalog item kosmetik (data-driven). `styleConfig` mereferensi PRESET ANIMASI
 * TERKURASI (mis. {"effect":"aurora-webgl","palette":"theme"}) — BUKAN CSS/JS
 * mentah dari user. Warna item earned ambil dari token tema aktif (`palette:"theme"`).
 */
model CosmeticItem {
  id                   String             @id @default(cuid())
  key                  String             @unique @db.VarChar(64)
  name                 String             @db.VarChar(120)
  type                 CosmeticType
  rarity               CosmeticRarity     @default(COMMON)
  /**
   * Slug preset/asset (mis. "twilight", "ring") untuk renderer.
   */
  previewRef           String             @db.VarChar(120)
  styleConfig          Json
  unlockType           CosmeticUnlockType @default(FREE)
  unlockLevel          Int?
  unlockAchievementKey String?            @db.VarChar(64)
  isActive             Boolean            @default(true)
  sortOrder            Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  userCosmetics        UserCosmetic[]

  @@index([type, isActive])
  @@index([unlockType])
}

/**
 * Kepemilikan kosmetik oleh User (unik per item).
 */
model UserCosmetic {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosmeticItemId String
  cosmeticItem   CosmeticItem   @relation(fields: [cosmeticItemId], references: [id], onDelete: Cascade)
  source         CosmeticSource @default(DEFAULT)
  acquiredAt     DateTime       @default(now())

  @@unique([userId, cosmeticItemId])
  @@index([userId])
}

/**
 * Kosmetik yang sedang di-equip seorang User. Equipped id sengaja "loose"
 * (String?, bukan FK) supaya item non-aktif tak pernah memblok baris user;
 * kepemilikan divalidasi di server action (sumber kebenaran authz).
 */
model UserProfileConfig {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  equippedBackgroundId   String?
  equippedBorderId       String?
  equippedNameplateId    String?
  equippedTitleId        String?
  accentColor            String?  @db.VarChar(7)
  customBackgroundUrl    String?  @db.VarChar(300)
  /** `image` | `lottie` — jenis unggahan latar kustom user. */
  customBackgroundMedia  String?  @db.VarChar(16)
  customBorderColor      String?  @db.VarChar(7)
  /**
   * String[] terurut dari Achievement.id yang di-showcase.
   */
  showcaseAchievementIds Json     @default("[]")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
