model ProductDiscoveryItem {
  id          String                @id @default(cuid())
  queryId     String
  query       ProductDiscoveryQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  marketplace ResearchMarketplace
  externalId  String
  name        String
  productUrl  String
  imageUrl    String?
  shopName    String?
  price       Float?
  rating      Float?
  reviewCount Int                   @default(0)
  soldCount   Int?
  hasPromo    Boolean               @default(false)
  promoText   String?
  categoryRank Int?

  @@unique([queryId, marketplace, externalId])
  @@index([queryId])
}

model ReviewIntelSource {
  id              String                  @id @default(cuid())
  productName     String
  competitorBrand String
  /** Registry key: shopee, tokopedia, femaledaily, sociolla, csv, … */
  platformKey     String                  @default("shopee")
  marketplace     ResearchMarketplace?
  productUrl      String
  status          ReviewIntelSourceStatus @default(PENDING)
  reviewCount     Int                     @default(0)
  totalReviewsReported Int?
  reviewsAccessible    Int?
  reviewsComplete      Boolean?
  lastAnalyzedAt  DateTime?
  errorMessage    String?
  createdById     String
  createdBy       User                    @relation("ReviewIntelSourceCreator", fields: [createdById], references: [id], onDelete: Cascade)
  brandId         String?
  brand           Brand?                  @relation(fields: [brandId], references: [id], onDelete: SetNull)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  reviews         ReviewRaw[]
  summary         ReviewIntelSummary?

  @@index([createdById])
  @@index([status])
  @@index([brandId])
  @@index([platformKey])
}

model ReviewRaw {
  id         String           @id @default(cuid())
  sourceId   String
  source     ReviewIntelSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId String?
  author     String?
  rating     Float?
  text       String           @db.Text
  reviewDate DateTime?
  createdAt  DateTime         @default(now())
  analysis   ReviewAnalysis?

  @@unique([sourceId, externalId])
  @@index([sourceId])
}

model ReviewAnalysis {
  id              String          @id @default(cuid())
  reviewId        String          @unique
  review          ReviewRaw       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  sentiment       ReviewSentiment
  complaintThemes String[]        @default([])
  praiseThemes    String[]        @default([])
  keywords        String[]        @default([])
  /** Tingkat keparahan keluhan 1-5 (null bila bukan keluhan). */
  complaintSeverity Int?
  /** Sinyal demografi terinferensi: { ageBand, skinType, gender } + confidence. */
  demographicHints Json?
  /** Persepsi nilai: "overpriced" | "worth_it" | "cheap" | null. */
  pricePerception String?
  /** Sinyal pembelian ulang terinferensi dari teks. */
  repeatPurchaseSignal Boolean?
  createdAt       DateTime        @default(now())

  @@index([sentiment])
}

model ReviewIntelSummary {
  id              String            @id @default(cuid())
  sourceId        String            @unique
  source          ReviewIntelSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  positivePct     Float             @default(0)
  neutralPct      Float             @default(0)
  negativePct     Float             @default(0)
  topComplaints   Json              @default("[]")
  topPraises      Json              @default("[]")
  keywordCloud    Json              @default("[]")
  timelineBuckets Json              @default("[]")
  gapOpportunity  String?           @db.Text
  /** Rencana aksi preskriptif (ActionPlan) hasil analisis review. */
  aiActionPlan    Json?
  /** Keparahan keluhan per tema: [{ theme, avgSeverity, count }]. */
  severityByTheme Json              @default("[]")
  /** Agregat demografi terinferensi: { ageBands[], skinTypes[], genders[] }. */
  demographics    Json              @default("{}")
  /** Metadata model AI per langkah analisis. */
  aiMeta          Json?
  updatedAt       DateTime          @updatedAt
}

model ResearchScrapeJob {
