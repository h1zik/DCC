  rateToBase   Decimal  @db.Decimal(18, 6)
  validFrom    DateTime
  createdAt    DateTime @default(now())

  @@unique([currencyCode, validFrom])
  @@index([currencyCode])
}

model FinanceJournalEntry {
  id              String                @id @default(cuid())
  entryDate       DateTime
  reference       String?
  memo            String?
  status          FinanceJournalStatus  @default(DRAFT)
  createdById     String
  createdBy       User                  @relation(fields: [createdById], references: [id], onDelete: Restrict)
  postedAt        DateTime?
  /**
   * Nomor jurnal sekuensial per tahun (mis. JE-2026-000123). Dibuat saat posting
   * sehingga draf tidak menyita nomor (audit trail bersih). Unik agar gampang
   * direferensikan di laporan & ekspor.
   */
  entryNumber     String?               @unique
  /**
   * Bila terisi, jurnal ini adalah jurnal pembalik (reversing entry) untuk
   * jurnal terposting yang lain. Best practice: posted entries tidak boleh
   * diedit/dihapus; koreksi dilakukan dengan jurnal pembalik.
   */
  reversesEntryId String?
  reversesEntry   FinanceJournalEntry?  @relation("FinanceJournalReversal", fields: [reversesEntryId], references: [id], onDelete: SetNull)
  reversedBy      FinanceJournalEntry[] @relation("FinanceJournalReversal")
  lines           FinanceJournalLine[]
  apPayments      FinanceApPayment[]
  arPayments      FinanceArPayment[]
  spendPayouts    FinanceSpendRequest[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([entryDate])
  @@index([status])
  @@index([reversesEntryId])
}

/**
 * Penguncian periode pembukuan (closing the books).
 * Setelah periode dikunci, jurnal dengan tanggal di dalamnya tidak boleh
 * diposting, dibalik, atau diedit. Hanya pengguna Finance yang dapat
 * mengunci/membuka periode.
 */
model FinancePeriodLock {
  id         String   @id @default(cuid())
  year       Int
  month      Int
  lockedById String
  lockedBy   User     @relation(fields: [lockedById], references: [id], onDelete: Restrict)
  lockedAt   DateTime @default(now())
  reason     String?  @db.VarChar(500)

  @@unique([year, month])
  @@index([year])
}

model FinanceJournalLine {
  id             String               @id @default(cuid())
  entryId        String
  entry          FinanceJournalEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId      String
  account        FinanceLedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  memo           String?
  debitBase      Decimal              @default(0) @db.Decimal(18, 2)
  creditBase     Decimal              @default(0) @db.Decimal(18, 2)
  currencyCode   String               @default("IDR") @db.VarChar(3)
  amountForeign  Decimal?             @db.Decimal(18, 2)
  fxRateSnapshot Decimal?             @db.Decimal(18, 6)
  brandId        String?
  brand          Brand?               @relation(fields: [brandId], references: [id], onDelete: SetNull)

  bankMatches BankStatementLine[]
  /**
   * Link opsional ke bill/invoice (lihat FinanceJournalLineLink).
   */
  link        FinanceJournalLineLink?
  /**
   * Lampiran (struk/invoice/dokumen pendukung).
   */
  attachments FinanceJournalLineAttachment[]

  @@index([accountId])
  @@index([entryId])
}

/**
 * Link dinamis antara satu baris jurnal dengan dokumen sub-ledger AP/AR.
 * Mode menentukan cara backend memproses baris saat posting:
 * - CREATE_BILL: line kredit ke akun AP control → buat FinanceApBill baru.
 * - PAY_BILL: line debit ke akun AP control → buat FinanceApPayment ke billId.
 * - CREATE_INVOICE: line debit ke akun AR control → buat FinanceArInvoice baru.
 * - RECEIVE_INVOICE: line kredit ke akun AR control → buat FinanceArPayment ke invoiceId.
 * Saat draft, link disimpan apa adanya. Saat posting, dokumen sub-ledger dibuat
 * /diperbarui dan field `createdBillId` / `createdInvoiceId` dicatat agar
 * relasi tetap dapat ditelusuri kalau kemudian jurnal di-reverse.
 */
model FinanceJournalLineLink {
  id     String             @id @default(cuid())
  lineId String             @unique
  line   FinanceJournalLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  mode FinanceJournalLineLinkMode

  // CREATE_BILL / CREATE_INVOICE
  vendorId   String?
  vendor     Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  partyName  String?
  partyEmail String?
  docNumber  String?
  docDate    DateTime?
  dueDate    DateTime?

  // PAY_BILL / RECEIVE_INVOICE
  billId    String?
  bill      FinanceApBill?    @relation("FinanceJournalLineLinkBill", fields: [billId], references: [id], onDelete: SetNull)
  invoiceId String?
  invoice   FinanceArInvoice? @relation("FinanceJournalLineLinkInvoice", fields: [invoiceId], references: [id], onDelete: SetNull)

  // Hasil setelah posting (untuk audit & undo manual)
  createdBillId    String?
  createdInvoiceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([billId])
  @@index([invoiceId])
  @@index([mode])
}

enum FinanceJournalLineLinkMode {
  CREATE_BILL
  PAY_BILL
  CREATE_INVOICE
  RECEIVE_INVOICE
}

/**
 * Lampiran (struk, invoice PDF, foto bukti) untuk satu baris jurnal.
 * File disimpan di `/public/uploads/finance/<entryId>/<id>-<filename>` (lokal)
 * — pindah ke object storage saat siap deploy multi-instance.
 */
model FinanceJournalLineAttachment {
  id           String             @id @default(cuid())
  lineId       String
  line         FinanceJournalLine @relation(fields: [lineId], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String             @db.VarChar(100)
  size         Int
  url          String             @db.VarChar(500)
  /**
   * SHA-256 hex dari isi file. Untuk deteksi duplikat upload.
   */
  hash         String?            @db.VarChar(64)
  uploadedById String
  uploadedBy   User               @relation("FinanceJournalLineAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  uploadedAt   DateTime           @default(now())

  @@index([lineId])
  @@index([hash])
}

