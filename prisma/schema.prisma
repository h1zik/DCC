enum TrendDigestMode {
  LIVE
  PARTIAL
  FAILED
}

enum TrendConfidence {
  HIGH
  MED
  LOW
}

enum TrendWowStatus {
  NEW
  ACCELERATING
  STABLE
  FADING
  GONE
}

enum TrendPhaseSource {
  computed
  llm_fallback
}

model TrendRadarDigest {
  id           String           @id @default(cuid())
  weekStart    DateTime
  weekEnd      DateTime
  status       TrendRadarStatus @default(PENDING)
  /** LIVE | PARTIAL | FAILED — kualitas data digest (bukan demo). */
  digestMode   TrendDigestMode  @default(LIVE)
  /** Ringkasan jumlah sinyal per sumber saat koleksi. */
  signalStats  Json?
  /** Pesan kualitas data untuk UI (mirip Keyword Intel dataNotice). */
  dataNotice   String?          @db.Text
  /** Digest minggu sebelumnya untuk perbandingan WoW. */
  priorDigestId String?
  narrative    String?          @db.Text
  /** Rencana aksi preskriptif (ActionPlan) untuk tren minggu ini. */
  aiActionPlan Json?
  /** Metadata model AI per langkah analisis. */
  aiMeta       Json?
  isGlobal     Boolean          @default(false)
  watchlistId  String?
  watchlist    TrendWatchlist?  @relation(fields: [watchlistId], references: [id], onDelete: SetNull)
  /** Snapshot konfigurasi sumber yang dipakai saat generate digest. */
  sourceConfig Json?
  errorMessage String?
  generatedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  items        TrendRadarItem[]

  @@index([status])
  @@index([isGlobal, weekStart])
  @@index([watchlistId])
  @@index([digestMode])
}

model TrendRadarItem {
  id               String            @id @default(cuid())
  digestId         String
  digest           TrendRadarDigest  @relation(fields: [digestId], references: [id], onDelete: Cascade)
  name             String
  dimension        TrendDimension
  phase            TrendPhase
  /** Trend Momentum Index 0–1 (metrik utama). */
  tmiScore         Float?
  /** Alias backward-compat — diset sama dengan tmiScore. */
  score            Float?
  confidence       TrendConfidence   @default(MED)
  phaseSource      TrendPhaseSource  @default(computed)
  wowStatus        TrendWowStatus?
  narrative        String?           @db.Text
  isGlobalPipeline Boolean           @default(false)
  /** Bukti terstruktur per sinyal. */
  evidence         Json              @default("[]")
  sources          Json              @default("[]")
  relatedProducts  Json              @default("[]")
  createdAt        DateTime          @default(now())

  @@index([digestId])
  @@index([phase])
}

