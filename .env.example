# =============================================================
# Dominatus Control Center — environment example
# Copy to `.env` and fill in your own values. Never commit `.env`.
# =============================================================

# ─────────────────────────────────────────────
# Core / App
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dcc?schema=public"
AUTH_SECRET=""                       # generate: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
DEFAULT_CEO_PASSWORD=""              # WAJIB untuk bootstrap akun CEO. Tidak ada
#                                    # default lagi — bila kosong, akun CEO tidak
#                                    # akan dibuat otomatis (fail-closed).
# CRON_SECRET=""                     # shared secret to authorize cron endpoints
# ALLOW_DEMO_DATA=""                 # "true" to allow synthetic demo scrape data when a
#                                    # scraper is unconfigured. Default: allowed in dev,
#                                    # BLOCKED in production (scrapers hard-fail instead
#                                    # of fabricating data). Set "true" to opt back in.

# ─────────────────────────────────────────────
# Profile Gamification (ala Steam) — rilis bertahap
# ─────────────────────────────────────────────
# PROFILE_GAMIFICATION_ENABLED=""    # OVERRIDE DARURAT. Kontrol utama = toggle admin
#                                    # di /admin/gamification (DB, runtime tanpa restart).
#                                    # Set "true"/"false" HANYA untuk memaksa on/off &
#                                    # mengunci toggle. Kosong = ikut toggle admin (default OFF).
# ATTENDANCE_ONTIME_CUTOFF="09:15"   # batas jam check-in "tepat waktu" (wall-clock
#                                    # Asia/Jakarta, "HH:mm"). Default 09:15 = masuk
#                                    # 09:00 + toleransi 15 menit.

# ─────────────────────────────────────────────
# Notifications (WhatsApp / Web Push)
# ─────────────────────────────────────────────
FONNTE_API_KEY=""
# VAPID keys — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:you@example.com"

# ─────────────────────────────────────────────
# Media
# ─────────────────────────────────────────────
GIPHY_API_KEY=""

# ─────────────────────────────────────────────
# Research Hub LLM
#   provider: gemini (default) | ollama-cloud
#   Provider bisa dipisah per tier: flash (job massal — klasifikasi review,
#   mention, insight kompetitor) vs pro (report, USP, concept lab, trend).
#   Contoh setup "flash Gemini + pro DeepSeek V4 Pro":
#     RESEARCH_LLM_PROVIDER="gemini"
#     RESEARCH_LLM_PROVIDER_PRO="ollama-cloud"   # + isi OLLAMA_API_KEY
# ─────────────────────────────────────────────
RESEARCH_LLM_PROVIDER="gemini"
# RESEARCH_LLM_PROVIDER_PRO=""       # override provider tier pro (kosong = ikut global)
# RESEARCH_LLM_PROVIDER_FLASH=""     # override provider tier flash (kosong = ikut global)
GEMINI_API_KEY=""
AGENT_LLM_MODEL="gemini-2.5-flash"   # model AI Agent in-app (default kode:
                                     # gemini-2.5-flash-lite — terlalu kecil untuk
                                     # analisis multi-step; disarankan 2.5-flash)
# GEMINI_MODEL=""                    # model tier flash (default: gemini-2.5-flash-lite)
# GEMINI_MODEL_PRO=""                # model tier pro — report/USP/concept/trend
#                                    # (default: gemini-2.5-pro; fallback otomatis ke
#                                    # gemini-2.5-flash bila kuota habis)
OLLAMA_API_KEY=""
OLLAMA_BASE_URL="https://ollama.com"
RESEARCH_OLLAMA_MODEL_FLASH="deepseek-v4-flash:cloud"
RESEARCH_OLLAMA_MODEL_PRO="deepseek-v4-pro:cloud"
RESEARCH_OLLAMA_THINK_FLASH="false"
RESEARCH_OLLAMA_THINK_PRO="high"

# ─────────────────────────────────────────────
# Apify — Scrapers (fallback). Values below are public actor slugs.
# ─────────────────────────────────────────────
APIFY_API_TOKEN=""
# Tokopedia
APIFY_ACTOR_TOKOPEDIA_SHOP=""
APIFY_ACTOR_TOKOPEDIA_REVIEWS=""
# TikTok Shop
APIFY_ACTOR_TIKTOK_SEARCH="kulqiz~tiktok-shop-scraper"
APIFY_ACTOR_TIKTOK_SHOP="kulqiz~tiktok-shop-scraper"
APIFY_ACTOR_TIKTOK_REVIEWS="kulqiz~tiktok-shop-scraper"
# Shopee
APIFY_ACTOR_SHOPEE_SHOP="gio21~shopee-scraper"
APIFY_ACTOR_SHOPEE_REVIEWS="gio21~shopee-product-detail"
APIFY_ACTOR_SHOPEE_AUTOCOMPLETE="xtracto~shopee-search-hint"
# Trends / Social
APIFY_ACTOR_TIKTOK_TRENDS="clockworks~tiktok-scraper"
APIFY_ACTOR_TIKTOK_COMMENTS="clockworks~tiktok-comments-scraper"
APIFY_ACTOR_INSTAGRAM="apify~instagram-scraper"
APIFY_ACTOR_PINTEREST="silentflow~pinterest-scraper-ppr"
BRAND_PINTEREST_MAX_PINS_PER_KEYWORD=80
APIFY_ACTOR_META_AD_LIBRARY="automly~facebook-ad-library-scraper"

# ─────────────────────────────────────────────
# DataForSEO — credentials from https://app.dataforseo.com/api-access
# ─────────────────────────────────────────────
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
DATAFORSEO_LOCATION_CODE="2360"
DATAFORSEO_LANGUAGE_CODE="id"
DATAFORSEO_MAX_KEYWORDS="30"
# SEO Toolkit: TTL cache respons DataForSEO (jam) untuk hemat biaya. Default 24.
DATAFORSEO_CACHE_TTL_HOURS="24"

# ─────────────────────────────────────────────
# Google Search Console (SEO Content Audit + data klik nyata)
# Setup: buat service account di Google Cloud → aktifkan "Search Console API"
# → tambahkan email service account sebagai user di properti Search Console.
# GSC_SITE_URL contoh: "sc-domain:brandanda.com" atau "https://brandanda.com/"
# ─────────────────────────────────────────────
GSC_SERVICE_ACCOUNT_EMAIL=""
# Private key PEM service account (newline boleh ditulis sebagai \n)
GSC_PRIVATE_KEY=""
GSC_SITE_URL=""

# ─────────────────────────────────────────────
# Trends — RSS / AI Read
# ─────────────────────────────────────────────
AI_READ_API_TOKEN=""
# Role efektif untuk read-API AI, TERIKAT server-side ke token (bukan dari
# header client). WAJIB diset — bila kosong/invalid semua request /api/ai ditolak
# 503 (fail-closed). Set ke role paling rendah yang dibutuhkan integrasi.
AI_READ_API_ROLE="CEO"
# Set "true" HANYA untuk dev/simulasi agar header x-dcc-role dihormati.
# Di production biarkan kosong/false supaya tidak bisa eskalasi hak.
AI_READ_API_ALLOW_ROLE_HEADER=""
# Token terpisah untuk MCP Research Team. Kredensial ini selalu dipetakan ke
# role MARKET_ANALYST dan hanya boleh memanggil /api/ai/research/* (403 untuk
# endpoint AI lain), sehingga jangan samakan nilainya dengan token utama.
AI_RESEARCH_API_TOKEN=""
TREND_RSS_FEEDS="https://wwd.com/beauty-industry-news/feed/,https://www.globalcosmeticsnews.com/feed/,https://www.premiumbeautynews.com/spip.php?page=backend,https://www.allure.com/feed/rss,https://www.nutraingredients.com/arc/outboundfeeds/rss/"

# ─────────────────────────────────────────────
# Internal Scraper API (VPS — Shopee / Tokopedia / Lazada)
# ─────────────────────────────────────────────
SCRAPER_API_URL="http://your-scraper-host:8000"
SCRAPER_API_KEY=""
# Product Discovery Shopee memakai actor `shopee-discover` (login-free via
# Google SERP) dengan hydrate harga/rating/sold via guest product API
# (include_details) — default AKTIF. Set "false" hanya bila guest API Shopee
# sedang diblokir dan run discover jadi sangat lambat/timeout; pipeline sudah
# punya fallback otomatis: discover hydrated → shopee-search → discover
# SERP-only → Apify.
SCRAPER_SHOPEE_DISCOVER_DETAILS=""
