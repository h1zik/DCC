{
  "name": "dominatus-control-center",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:db": "vitest run --config vitest.db.config.ts",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:diff": "prisma migrate diff --from-schema-datasource prisma/schema.prisma --to-schema-datamodel prisma/schema.prisma --script",
    "db:backup": "npx tsx prisma/scripts/backup-db.ts",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:migrate-status": "prisma migrate status",
    "db:evolve-kanban": "npm run db:evolve-kanban-position && npm run db:evolve-room-kanban-columns",
    "db:evolve-kanban-position": "prisma db execute --file prisma/scripts/evolve-task-kanban-position.sql --schema prisma/schema.prisma",
    "db:evolve-room-kanban-columns": "prisma db execute --file prisma/scripts/evolve-room-kanban-columns.sql --schema prisma/schema.prisma",
    "db:evolve-pipeline-enum": "prisma db execute --file prisma/scripts/evolve-pipeline-stage-enum.sql --schema prisma/schema.prisma",
    "db:backfill-kanban": "npx tsx prisma/scripts/backfill-kanban-hybrid.ts",
    "db:verify-kanban": "prisma db execute --file prisma/scripts/verify-kanban-migration.sql --schema prisma/schema.prisma",
    "db:clear-projects": "npx tsx prisma/scripts/guard-destructive.ts && prisma db execute --file prisma/clear-projects.sql --schema prisma/schema.prisma",
    "db:seed": "npx tsx prisma/scripts/guard-destructive.ts && prisma db seed",
    "db:seed-gamification": "npx tsx prisma/scripts/seed-gamification.ts",
    "cosmetics:generate": "npx tsx prisma/scripts/generate-cosmetic-assets.ts",
    "documents:backfill-search": "npx tsx scripts/backfill-room-document-search.ts",
    "db:backfill-gamification": "npx tsx prisma/scripts/backfill-gamification.ts",
    "db:studio": "prisma studio",
    "eval:research": "tsx scripts/eval-review-analysis.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@base-ui/react": "^1.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@livekit/components-react": "^2.9.23",
    "@livekit/components-styles": "^1.2.0",
    "@lottiefiles/dotlottie-react": "^0.19.7",
    "@prisma/client": "6.19.3",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-code-block-lowlight": "3.23.1",
    "@tiptap/extension-image": "3.23.1",
    "@tiptap/extension-link": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.23.1",
    "@tiptap/extension-table": "3.23.1",
    "@tiptap/extension-task-item": "^3.23.1",
    "@tiptap/extension-task-list": "^3.23.1",
    "@tiptap/extension-text-align": "^3.23.1",
    "@tiptap/extension-text-style": "^3.23.1",
    "@tiptap/extension-youtube": "3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@vladmandic/face-api": "^1.7.15",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "echarts": "^5.6.0",
    "emoji-picker-react": "^4.18.0",
    "fflate": "^0.8.3",
    "fluent-ffmpeg": "^2.1.3",
    "google-trends-api": "^4.9.2",
    "groq-sdk": "^1.3.0",
    "html-to-docx": "^1.8.0",
    "jspdf": "^2.5.2",
    "livekit-client": "^2.20.1",
    "livekit-server-sdk": "^2.17.0",
    "lowlight": "3.3.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.42.2",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "prisma": "6.19.3",
    "react": "19.2.4",
